<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Syndiceo</title>
    <link rel="icon" type="image/png" href="~/images/logo.png" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    
    @* АВТОМАТИЧЕН REDIRECT ЗА АДМИНА *@
    @if (User.Identity.IsAuthenticated && User.IsInRole("Admin"))
    {
        var currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
        var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();

        // Ако админът се опита да отвори началната страница (Home/Index), го пращаме в таблото
        if (currentController == "Home" && currentAction == "Index")
        {
            <script>window.location.href = '@Url.Action("AdminDashboard", "Administrator")';</script>
        }
    }
</head>
<body class="bg-light bg-opacity-50">

    <div class="bg-objects"></div>

    <header class="modern-header-alt shadow-sm bg-white sticky-top">
        <div class="container-xxl d-flex justify-content-between align-items-center py-2">
            
            <div class="d-flex align-items-center gap-4">
                <a href="@(User.IsInRole("Admin") ? "/Administrator/AdminDashboard" : "/")" class="logo d-flex align-items-center gap-2 text-decoration-none">
                    <img src="~/images/logo.png" alt="Logo" height="38">
                    <span class="fw-bold fs-4 text-dark" style="letter-spacing: -1.2px;">Syndiceo</span>
                    @if (User.IsInRole("Admin"))
                    {
                        <span class="badge bg-primary bg-opacity-10 text-primary fw-bold ms-1" style="font-size: 0.65rem; letter-spacing: 0.5px; border: 1px solid rgba(44, 82, 130, 0.2);">ADMIN</span>
                    }
                </a>

                <nav class="d-none d-lg-block">
                    <ul class="nav-menu d-flex gap-2 mb-0 list-unstyled border-start ps-4 ms-2">
                        @if (User.Identity.IsAuthenticated)
                        {
                            @if (User.IsInRole("Admin"))
                            {
                                <li><a class="nav-link-custom active" asp-controller="Administrator" asp-action="AdminDashboard"><i class="bi bi-grid-1x2-fill me-2"></i>Контролен панел</a></li>
                            }
                            else
                            {
                                <li><a href="/" class="nav-link-custom @(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")">Начало</a></li>
                                <li><a class="nav-link-custom" asp-controller="User" asp-action="Residences">🏠 Моите Имоти</a></li>
                                <li><a class="nav-link-custom" asp-controller="User" asp-action="Reports">📢 Сигнали</a></li>
                            }
                        }
                        else
                        {
                            <li><a href="/" class="nav-link-custom active">Начало</a></li>
                            <li><a href="#features" class="nav-link-custom text-muted">Възможности</a></li>
                        }
                    </ul>
                </nav>
            </div>

            <div class="auth-section">
                <partial name="_LoginPartial" />
            </div>
        </div>
    </header>

    <main role="main" class="content-wrapper container-xxl">
        @RenderBody()
    </main>

   <footer class="footer mt-auto py-4 bg-white border-top shadow-sm">
    <div class="container">
        <div class="row align-items-center gy-3">
            <div class="col-md-4 text-center text-md-start">
                <p class="text-muted mb-0 small">
                    &copy; 2026 <strong>Syndiceo</strong>. Всички права запазени.
                </p>
            </div>

            <div class="col-md-4 text-center">
                <a asp-area="" asp-controller="Home" asp-action="Privacy" 
                   class="text-decoration-none text-muted small hover-primary mx-3">
                    Политика за поверителност
                </a>
            </div>

            <div class="col-md-4 text-center text-md-end">
                <span class="text-muted small">
                    Изработено от <span class="fw-bold text-dark">NYXON</span>
                </span>
            </div>
        </div>
    </div>
</footer>

    <style>
        .nav-link-custom {
            color: #4A5568; 
            font-weight: 600; 
            text-decoration: none; 
            padding: 10px 18px; 
            border-radius: 12px; 
            transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
            font-size: 0.92rem;
            display: flex;
            align-items: center;
        }
        .nav-link-custom:hover { 
            color: #2C5282; 
            background: #F1F5F9; 
        }
        .nav-link-custom.active { 
            color: #2C5282; 
            background: rgba(44, 82, 130, 0.08); 
        }

        .modern-header-alt { 
            background: rgba(255, 255, 255, 0.9) !important;
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border-bottom: 1px solid #E2E8F0; 
            z-index: 1050; 
            height: 75px; 
            display: flex; 
            align-items: center; 
        }

        .content-wrapper { 
            min-height: 85vh; 
            padding-top: 2.5rem; 
            padding-bottom: 5rem;
        }

        body { font-family: 'Inter', system-ui, -apple-system, sans-serif; }
        /* Прави футъра по-елегантен */
.footer {
    position: relative;
    z-index: 10;
}

/* Ефект при посочване на линка за поверителност */
.hover-primary:hover {
    color: #2C5282 !important;
    text-decoration: underline !important;
    transition: all 0.2s ease;
}

/* Гарантира, че ако съдържанието е малко, футърът пак ще е долу */
body {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
}

main {
    flex: 1;
}
    </style>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>