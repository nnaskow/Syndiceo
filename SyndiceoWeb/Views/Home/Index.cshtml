@{
    ViewData["Title"] = "Начална страница";
    var firstName = User.FindFirst("FirstName")?.Value ?? User.Identity?.Name;
}

<div class="container mt-5">

    <!-- HERO -->
    <div class="bg-white p-5 rounded hero-shadow text-center mb-5">
        <img src="~/images/logo.png" height="140" class="mb-4" />

        @if (!User.Identity.IsAuthenticated)
        {
            <h1 class="display-5 fw-bold mb-3">Добре дошли в Syndiceo</h1>

            <p class="lead mb-4">
                Помощникът за управление на входни и апартаментни такси,
                създаден специално за вас.
            </p>
            <p class="mb-4">
                Влезте в профила си или се регистрирайте, за да получите достъп
                до вашата информация.
            </p>

            <div class="d-flex justify-content-center gap-3">
                <a class="btn btn-outline-primary btn-lg"
                   asp-area="Identity"
                   asp-page="/Account/Login">
                    Вход
                </a>

                <a class="btn btn-primary btn-lg"
                   asp-area="Identity"
                   asp-page="/Account/Register">
                    Регистрация
                </a>
            </div>
        }
        else
        {
            <h1 class="display-5 fw-bold mb-3">
                Добре дошли, @firstName 👋
            </h1>

            <p class="fs-5 mb-2">
                Радваме се да ви видим отново в <strong>Syndiceo</strong>!
            </p>

            <p class="text-muted mb-4">
                Днес е чудесен ден да проверите текущите си такси, да видите статуса на апартамента ви
                или да подадете бързо сигнал за какъвто и да е проблем.
            </p>

            <p class="text-muted">
                Също така можете да прегледате историята си или просто да се уверите, че всичко е наред.
                Syndiceo е тук, за да направи управлението на апартамента ви лесно и удобно.
            </p>
        }
    </div>

    @if (!User.Identity.IsAuthenticated)
    {
        <div class="row text-center mb-5">
            <div class="col-md-8 mx-auto">
                <h2 class="fw-bold mb-3">Какво представлява системата?</h2>
                <p class="text-muted">
                    Syndiceo е вашият помощник, който ви позволява лесно и прозрачно
                    да следите входните и апартаментните си такси,
                    както и да подавате сигнали при възникнали проблеми или нередности.
                </p>
            </div>
        </div>

        <div class="row text-center g-4 mb-5">
            <div class="col-md-4">
                <div class="p-4 bg-light rounded h-100 shadow-sm">
                    <h5 class="fw-bold mb-3">📊 Преглед на такси</h5>
                    <p class="text-muted">
                        Вижте начислените входни и апартаментни такси,
                        текущото си състояние и историята на плащанията.
                    </p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="p-4 bg-light rounded h-100 shadow-sm">
                    <h5 class="fw-bold mb-3">📝 Подаване на сигнали</h5>
                    <p class="text-muted">
                        Подайте сигнал при техническа неизправност
                        или проблем в общите части на сградата.
                    </p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="p-4 bg-light rounded h-100 shadow-sm">
                    <h5 class="fw-bold mb-3">🔒 Сигурен достъп</h5>
                    <p class="text-muted">
                        Всеки потребител има защитен личен профил
                        с достъп само до своята информация.
                    </p>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="row text-center mb-5">
            <div class="col-md-8 mx-auto">
                <h2 class="fw-bold mb-3">Вашият контролен панел</h2>
                <p class="text-muted">
                    Оттук можете да управлявате своята информация,
                    да следите начислените такси и да подавате сигнали.
                </p>
            </div>
        </div>

        <div class="row text-center g-4 mb-5">

            <div class="col-md-4">
                <div class="p-4 bg-light rounded h-100 shadow-sm">
                    <h5 class="fw-bold mb-3">💰 Моите такси</h5>
                    <p class="text-muted">
                        Проверете текущите си задължения и историята на плащанията.
                    </p>
                    <a class="btn btn-outline-primary" asp-controller="User" asp-action="ApartmentTaxes" asp-route-apartmentId="1">
                        💰 Моите такси
                    </a>
                </div>
            </div>

            <div class="col-md-4">
                <div class="p-4 bg-light rounded h-100 shadow-sm">
                    <h5 class="fw-bold mb-3">🏢 Моите жилища</h5>
                    <p class="text-muted">
                        Вижте информацията за вашите жилища и статуса на заявката си.
                    </p>
                    <a class="btn btn-outline-primary" asp-controller="User" asp-action="Residences">
                        🏢 Моите жилища
                    </a>
                </div>
            </div>

            <div class="col-md-4">
                <div class="p-4 bg-light rounded h-100 shadow-sm">
                    <h5 class="fw-bold mb-3">🚨 Сигнали</h5>
                    <p class="text-muted">
                        Съобщете за проблем или нередност директно към управителя.
                    </p>
                    <a class="btn btn-outline-primary mt-2"
                       asp-controller="User"
                       asp-action="Reports">
                        📢 Моите сигнали
                    </a>
                </div>
            </div>

        </div>
    }
</div>