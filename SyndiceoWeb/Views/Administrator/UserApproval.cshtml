@using System.Linq
@model IEnumerable<SyndiceoWeb.Areas.Identity.Data.SyndiceoWebUser>
@{
    ViewData["Title"] = "Одобряване на потребители";
}

<style>
    .approval-card {
        transition: all 0.25s ease;
        border: 1px solid #E2E8F0;
        background: white;
        border-radius: 16px;
    }
    .approval-card:hover {
        border-color: #2C5282;
        background-color: #F8FAFC;
        transform: scale(1.005);
    }
    .user-icon-circle {
        width: 48px;
        height: 48px;
        background: linear-gradient(135deg, #2C5282, #4A5568);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 12px;
        font-size: 1.2rem;
        box-shadow: 0 4px 10px rgba(44, 82, 130, 0.2);
    }
    .action-btn-group .btn {
        border-radius: 10px;
        font-weight: 600;
        padding: 0.5rem 1rem;
    }
</style>

<div class="container py-5">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-5 gap-3">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-2">
                    <li class="breadcrumb-item"><a asp-action="AdminDashboard">Табло</a></li>
                    <li class="breadcrumb-item active">Одобряване</li>
                </ol>
            </nav>
            <h2 class="fw-bold m-0" style="color: #2D3748;">👤 Нови регистрации</h2>
            <p class="text-muted mb-0">Преглед и активиране на нови потребителски акаунти.</p>
        </div>
        <div class="text-md-end">
            <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 px-3 py-2 rounded-pill fw-bold">
                <i class="bi bi-person-plus-fill me-1"></i> @ViewBag.Pendings чакащи за активация
            </span>
        </div>
    </div>

    <div class="card border-0 shadow-sm p-4" style="border-radius: 20px;">
        <div class="table-responsive">
            <table class="table align-middle mb-0 table-borderless">
                <thead>
                    <tr class="text-muted small text-uppercase" style="letter-spacing: 1px; border-bottom: 2px solid #F1F5F9;">
                        <th class="pb-3 fw-bold">Данни за потребителя</th>
                        <th class="pb-3 fw-bold text-center">Системно ID</th>
                        <th class="pb-3 text-end fw-bold">Действия по активиране</th>
                    </tr>
                </thead>
                <tbody>
                    @if (ViewBag.Pendings == 0)
                    {
                        <tr>
                            <td colspan="3" class="text-center py-5">
                                <div class="mb-3" style="font-size: 3rem;">🎉</div>
                                <h5 class="fw-bold text-dark">Няма нови чакащи регистрации</h5>
                                <p class="text-muted">Всички потребители са прегледани и одобрени.</p>
                                <a asp-action="AdminDashboard" class="btn btn-outline-primary btn-sm rounded-pill px-4">Връщане към таблото</a>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var user in Model)
                        {
                            <tr class="approval-card" style="border-bottom: 8px solid white;">
                                <td class="py-4 ps-3">
                                    <div class="d-flex align-items-center">
                                        <div class="user-icon-circle me-3">
                                            @user.Email.Substring(0, 1).ToUpper()
                                        </div>
                                        <div>
                                            <div class="fw-bold text-dark fs-5">@user.Email</div>
                                            <div class="text-muted small">Дата на регистрация: @DateTime.Now.ToString("dd.MM.yyyy")</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="text-center">
                                    <code class="bg-light px-2 py-1 rounded text-primary small">@user.Id.Substring(0, 12)...</code>
                                </td>
                                <td class="text-end pe-3">
                                    <div class="d-flex gap-2 justify-content-end action-btn-group">
                                        <form asp-action="ApproveUserAccount" method="post" class="m-0">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="userId" value="@user.Id" />
                                            <button type="submit" class="btn btn-success shadow-sm">
                                                <i class="bi bi-person-check-fill me-1"></i> Одобри
                                            </button>
                                        </form>

                                        <form asp-action="RejectUser" method="post" onsubmit="return confirm('Сигурни ли сте, че искате да отхвърлите и изтриете този потребител?');" class="m-0">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="userId" value="@user.Id" />
                                            <button type="submit" class="btn btn-outline-danger">
                                                <i class="bi bi-x-circle"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>