@using System.Linq
@model IEnumerable<SyndiceoWeb.Areas.Identity.Data.SyndiceoWebUser>
@{
    ViewData["Title"] = "Одобряване на потребители";
}

<style>
    .approval-card-row {
        transition: all 0.25s ease;
        background: white;
        border-bottom: 8px solid #F8FAFC;
    }

    .user-icon-circle {
        width: 44px;
        height: 44px;
        background: linear-gradient(135deg, #2C5282, #4A5568);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 12px;
        font-weight: bold;
        box-shadow: 0 4px 10px rgba(44, 82, 130, 0.15);
        flex-shrink: 0;
    }

   @@media (max-width: 767.98px) {
        .approval-table thead {
            display: none;
        }

        .approval-table tbody tr {
            display: block;
            margin-bottom: 1rem;
            border: 1px solid #E2E8F0 !important;
            border-radius: 20px;
            padding: 1.25rem;
            box-shadow: 0 2px 8px rgba(0,0,0,0.04);
        }

        .approval-table td {
            display: block;
            width: 100%;
            padding: 0.5rem 0 !important;
            border: none !important;
            text-align: left !important;
        }

            .approval-table td:last-child {
                border-top: 1px solid #F1F5F9 !important;
                margin-top: 0.5rem;
                padding-top: 1rem !important;
            }

        .action-btn-group {
            width: 100%;
        }

            .action-btn-group form {
                flex: 1;
            }

            .action-btn-group .btn {
                width: 100%;
                justify-content: center;
            }
    }

    .btn-approve {
        background: #38A169;
        color: white;
        border: none;
        border-radius: 10px;
        font-weight: 600;
        padding: 0.5rem 1.25rem;
        transition: transform 0.2s;
    }

        .btn-approve:hover {
            background: #2F855A;
            color: white;
            transform: translateY(-1px);
        }
</style>

<div class="container py-4 py-md-5">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-2 small">
                    <li class="breadcrumb-item"><a asp-action="AdminDashboard" class="text-decoration-none">Табло</a></li>
                    <li class="breadcrumb-item active">Одобряване</li>
                </ol>
            </nav>
            <h2 class="fw-bold m-0" style="color: #2D3748;">👤 Регистрации</h2>
        </div>
        <div>
            <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 px-3 py-2 rounded-pill fw-bold">
                <i class="bi bi-person-plus-fill me-1"></i> @ViewBag.Pendings чакащи
            </span>
        </div>
    </div>

    <div class="card border-0 shadow-sm p-2 p-md-4" style="border-radius: 24px;">
        <div class="table-responsive border-0">
            <table class="table align-middle mb-0 table-borderless approval-table">
                <thead>
                    <tr class="text-muted small text-uppercase" style="letter-spacing: 1px; border-bottom: 2px solid #F1F5F9;">
                        <th class="pb-3 fw-bold ps-3">Потребител</th>
                        <th class="pb-3 fw-bold text-center">ID</th>
                        <th class="pb-3 text-end fw-bold pe-3">Активиране</th>
                    </tr>
                </thead>
                <tbody>
                    @if (ViewBag.Pendings == 0)
                    {
                        <tr>
                            <td colspan="3" class="text-center py-5">
                                <div class="mb-3 fs-1">🎉</div>
                                <h5 class="fw-bold text-dark">Всичко е чисто!</h5>
                                <p class="text-muted small">Няма нови чакащи регистрации за преглед.</p>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var user in Model)
                        {
                            <tr class="approval-card-row">
                                <td class="py-4 ps-4">
                                    <div class="d-flex align-items-center">
                                        <div class="user-icon-circle me-3 shadow-sm">
                                            @user.FirstName.Substring(0, 1).ToUpper()@user.LastName.Substring(0, 1).ToUpper()
                                        </div>
                                        <div>
                                            <div class="fw-800 text-dark fs-5 mb-0">
                                                @user.FirstName @user.LastName
                                            </div>
                                            <div class="text-muted small">
                                                <i class="bi bi-envelope me-1"></i> @user.Email
                                            </div>
                                        </div>
                                    </div>
                                </td>
                                <td class="text-md-center">
                                    <span class="d-md-none text-muted small me-1">ID:</span>
                                    <code class="bg-light px-2 py-1 rounded text-primary small">@user.Id.Substring(0, 8)...</code>
                                </td>
                                <td class="text-md-end pe-md-3">
                                    <div class="d-flex gap-2 justify-content-md-end action-btn-group">
                                        <form asp-action="ApproveUserAccount" method="post" class="m-0 flex-grow-1 flex-md-grow-0">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="userId" value="@user.Id" />
                                            <button type="submit" class="btn btn-approve btn-sm w-100">
                                                <i class="bi bi-person-check-fill me-1"></i> Одобри
                                            </button>
                                        </form>

                                        <form asp-action="RejectUser" method="post" onsubmit="return confirm('Изтриване на този акаунт?');" class="m-0">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="userId" value="@user.Id" />
                                            <button type="submit" class="btn btn-outline-danger btn-sm px-3">
                                                <i class="bi bi-trash3"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div class="mt-4 text-center text-md-start">
        <a asp-action="AdminDashboard" class="text-decoration-none text-muted small fw-bold">
            <i class="bi bi-arrow-left me-1"></i> Към таблото
        </a>
    </div>
</div>