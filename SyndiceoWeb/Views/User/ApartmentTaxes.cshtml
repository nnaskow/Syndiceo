@model IEnumerable<Syndiceo.Data.Models.Debt>
@{
    var apt = ViewBag.Apartment as Syndiceo.Data.Models.Apartment;
    var transactions = ViewBag.Transactions as IEnumerable<Syndiceo.Data.Models.ApartmentTransaction>;
    decimal totalRemaining = Model.Sum(d => d.RemainingSum ?? 0);
    ViewData["Title"] = "Сметки и такси";
}

<style>
    .gradient-header {
        background: linear-gradient(135deg, #2C5282 0%, #1A365D 100%);
        color: white;
        padding: 2rem;
        border-radius: 24px;
        position: relative;
        overflow: hidden;
        min-height: 140px;
        display: flex;
        align-items: center;
    }

    .amount-badge {
        background: rgba(255, 255, 255, 0.12);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.2);
        padding: 1rem;
        border-radius: 18px;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
    }

    .bg-icon-wallet {
        position: absolute;
        right: -15px;
        bottom: -20px;
        font-size: 7rem;
        color: white;
        opacity: 0.1;
        transform: rotate(-15deg);
        pointer-events: none;
    }

    .table-container {
        background: white;
        border-radius: 20px;
        border: 1px solid #E2E8F0;
        overflow: hidden;
    }

    .status-pill {
        font-size: 0.65rem;
        font-weight: 800;
        padding: 0.3rem 0.7rem;
        border-radius: 50px;
        text-transform: uppercase;
        white-space: nowrap;
    }

    .category-tag {
        font-size: 0.65rem;
        font-weight: 700;
        background: #F1F5F9;
        color: #475569;
        padding: 3px 8px;
        border-radius: 6px;
        border: 1px solid #E2E8F0;
        white-space: nowrap;
    }

    @@media (max-width: 991.98px) {
        .gradient-header {
            padding: 1.5rem;
            border-radius: 18px;
            text-align: center;
            flex-direction: column;
        }
        
        .header-content .row {
            flex-direction: column;
        }

        .amount-badge {
            margin-top: 1rem;
            width: 100%;
        }

        .bg-icon-wallet {
            font-size: 5rem;
        }

        .table-responsive {
            margin: 0 -0.5rem; 
        }

        .table td, .table th {
            font-size: 0.85rem;
            padding: 0.75rem 0.5rem !important;
        }
    }

    @@media (max-width: 575.98px) {
        .container { padding-left: 15px; padding-right: 15px; }
        h3 { font-size: 1.2rem; }
        .address-text { font-size: 0.8rem; }
    }
</style>

<div class="container py-4 py-md-5">
    
    <div class="d-flex justify-content-between align-items-center mb-4">
        <nav aria-label="breadcrumb" class="d-none d-sm-block">
            <ol class="breadcrumb mb-0 small fw-bold">
                <li class="breadcrumb-item"><a asp-action="Residences" class="text-decoration-none text-muted">Имоти</a></li>
                <li class="breadcrumb-item active text-primary">Сметки</li>
            </ol>
        </nav>
        <div class="d-flex align-items-center gap-4">
        <a asp-controller="Home" asp-action="Index" class="btn btn-link btn-sm text-decoration-none fw-bold text-muted p-0">
            <i class="bi bi-arrow-left me-1"></i> Назад
        </a>
        </div>
    </div>

    <div class="gradient-header shadow-sm mb-4 mb-md-5">
        <div class="header-content w-100">
            <div class="row align-items-center">
                <div class="col-lg-8">
                    <div class="d-flex align-items-center justify-content-center justify-content-lg-start mb-2">
                        <div class="bg-white text-primary rounded-circle me-3 d-none d-md-flex align-items-center justify-content-center shadow-sm" style="width: 40px; height: 40px; flex-shrink: 0;">
                            <i class="bi bi-house-heart-fill"></i>
                        </div>
                        <h4 class="mb-0 fw-bold text-white">Ап. @apt.ApartmentNumber, вх. @apt.Entrance.EntranceName</h4>
                    </div>
                    <div class="address-text text-white opacity-75 ps-lg-1">
                        <i class="bi bi-geo-alt-fill me-1 small"></i>
                        @apt.Entrance.Block.Address.Street № @apt.Entrance.Block.BlockName
                    </div>
                </div>
                <div class="col-lg-4 text-center text-lg-end">
                    <div class="amount-badge">
                        <small class="d-block opacity-75 mb-1 text-uppercase fw-bold" style="font-size: 0.6rem; letter-spacing: 1px;">Общо дължимо</small>
                        <h3 class="fw-bold mb-0">€@totalRemaining.ToString("F2")</h3>
                    </div>
                </div>
            </div>
        </div>
        <i class="bi bi-wallet2 bg-icon-wallet"></i>
    </div>

    <div class="row g-4 g-lg-5">
        
        <div class="col-lg-7">
            <div class="d-flex align-items-center mb-3">
                <div class="bg-primary bg-opacity-10 p-2 rounded-3 me-2 text-primary">
                    <i class="bi bi-clipboard-data-fill"></i>
                </div>
                <h5 class="fw-bold mb-0 text-dark">Такси на апартамента</h5>
            </div>

            <div class="table-container shadow-sm p-1">
                <div class="table-responsive">
                    <table class="table align-middle mb-0" style="min-width: 400px;">
                        <thead class="bg-light bg-opacity-50 small text-muted">
                            <tr>
                                <th class="border-0 ps-3">Описание</th>
                                <th class="border-0">Сума</th>
                                <th class="border-0">Остава</th>
                                <th class="border-0 text-end pe-3">Статус</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var debt in Model)
                            {
                                <tr class="border-top">
                                    <td class="ps-3 py-3">
                                        <div class="fw-bold text-dark">Такса</div>
                                        <div class="text-muted" style="font-size: 0.7rem;">Общо за апартамента</div>
                                    </td>
                                    <td class="small">@debt.TotalSum.ToString("F2")</td>
                                    <td class="fw-bold @(debt.RemainingSum > 0 ? "text-danger" : "text-success")">
                                        @debt.RemainingSum?.ToString("F2")
                                    </td>
                                    <td class="text-end pe-3">
                                        <span class="status-pill @(debt.RemainingSum <= 0 ? "bg-success bg-opacity-10 text-success" : "bg-danger bg-opacity-10 text-danger")">
                                            @(debt.RemainingSum <= 0 ? "Платено" : "Дължимо")
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="d-flex align-items-center mb-3">
                <div class="bg-info bg-opacity-10 p-2 rounded-3 me-2 text-info">
                    <i class="bi bi-receipt"></i>
                </div>
                <h5 class="fw-bold mb-0 text-dark">Детайли по таксите</h5>
            </div>

            <div class="table-container shadow-sm p-1">
                <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0" style="min-width: 350px;">
                        <thead class="small text-muted">
                            <tr>
                                <th class="border-0 ps-3">Тип</th>
                                <th class="border-0">Описание</th>
                                <th class="border-0 text-end pe-3">Сума</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var tr in transactions)
                            {
                                <tr class="border-top">
                                    <td class="ps-3 py-3">
                                        <span class="category-tag">@tr.Category?.Name</span>
                                    </td>
                                    <td class="small text-muted text-truncate" style="max-width: 120px;">@tr.Description</td>
                                    <td class="text-end pe-3 fw-bold small">€@tr.Amount.ToString("F2")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    <div class="row mt-5">
        <div class="col-12">
            <div class="card border-0 shadow-sm overflow-hidden" style="border-radius: 24px; background: #fdfdfd; border: 1px solid #eee !important;">
                <div class="card-header bg-white border-0 p-4 pb-0">
                    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
                        <div>
                            <h5 class="fw-bold mb-1"><i class="bi bi-building text-primary me-2"></i>Такси на входа</h5>
                            <p class="text-muted small mb-0">Последни общи разходи за етажната собственост</p>
                        </div>
                        <div class="text-md-end">
                        </div>
                    </div>
                </div>
                <div class="card-body p-4">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="small text-uppercase text-muted opacity-75" style="font-size: 0.65rem; letter-spacing: 0.5px;">
                                <tr>
                                    <th class="border-0">Дата</th>
                                    <th class="border-0">Категория</th>
                                    <th class="border-0">Описание</th>
                                    <th class="border-0 text-end">Сума</th>
                                </tr>
                            </thead>
                                <tbody>
                                    @foreach (var tr in ViewBag.EntranceTransactions)
                                {
                                    var isIncome = tr.Category?.Kind == "Приход";
        
                                    <tr class="border-top-0">
                                        <td class="text-muted small border-light">@tr.TransDate.ToString("dd.MM.yyyy")</td>
            
                                        <td class="border-light">
                                            <span class="status-pill @(isIncome ? "bg-success bg-opacity-10 text-success" : "bg-danger bg-opacity-10 text-danger")">
                                                @(tr.Category?.Kind ?? "Неизвестно")
                                            </span>
                                        </td>
            
                                        <td class="border-light">
                                            <span class="badge rounded-pill fw-normal border text-dark bg-white shadow-sm" style="font-size: 0.7rem; padding: 0.4rem 0.7rem;">
                                                @tr.Category?.Name
                                            </span>
                                        </td>
                        
                                        <td class="text-end fw-bold @(isIncome ? "text-success" : "text-danger") border-light">
                                            @(isIncome ? "+" : "-")€@tr.Amount.ToString("F2")
                                        </td>
                                    </tr>
                                }
                            
                                </tbody>                       
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
