@model IEnumerable<Syndiceo.Data.Models.Debt>
@{
    var apt = ViewBag.Apartment as Syndiceo.Data.Models.Apartment;
    var transactions = ViewBag.Transactions as IEnumerable<Syndiceo.Data.Models.ApartmentTransaction>;
    decimal totalRemaining = Model.Sum(d => d.RemainingSum ?? 0);
    var address = ViewBag.Addres as Syndiceo.Data.Models.Address;
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0">Сметки и такси</h2>
            <span class="text-muted">ул. @address.Street @apt.ApartmentNumber, Вход @apt.Entrance.EntranceName</span>
        </div>
        <a asp-action="Residences" class="btn btn-outline-secondary btn-sm">Назад към имоти</a>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm bg-primary text-white p-3">
                <small class="opacity-75">Общо за плащане</small>
                <h2 class="fw-bold mb-0">@totalRemaining.ToString("F2") лв.</h2>
                <i class="bi bi-wallet2 position-absolute end-0 bottom-0 me-3 mb-2 opacity-25" style="font-size: 3rem;"></i>
            </div>
        </div>
    </div>

    <h4 class="fw-bold mb-3">📋 Задължения</h4>
    <div class="card border-0 shadow-sm mb-5">
        <table class="table align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Период / Описание</th>
                    <th>Обща сума</th>
                    <th>Платено</th>
                    <th>Остава</th>
                    <th class="text-end">Статус</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var debt in Model)
                {
                    <tr>
                        <td><span class="fw-bold">Месечна такса</span></td>
                        <td>@debt.TotalSum.ToString("F2") лв.</td>
                        <td class="text-success">@debt.PaidSum.ToString("F2") лв.</td>
                        <td class="fw-bold text-danger">@debt.RemainingSum?.ToString("F2") лв.</td>
                        <td class="text-end">
                            @if (debt.RemainingSum <= 0)
                            {
                                <span class="badge bg-success">Платено</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">Дължимо</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <h4 class="fw-bold mb-3">📜 Подробно</h4>
    <div class="card border-0 shadow-sm">
        <table class="table table-sm align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Дата</th>
                    <th>Категория</th>
                    <th>Описание</th>
                    <th class="text-end">Сума</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var tr in transactions)
                {
                    <tr>
                        <td class="text-muted">@DateTime.Now.ToShortDateString()</td> @* Тук сложи реална дата ако имаш в таблицата *@
                        <td><span class="badge bg-info-subtle text-info border border-info">@tr.Category?.Name</span></td>
                        <td>@tr.Description</td>
                        <td class="text-end fw-bold">@tr.Amount.ToString("F2") лв.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>