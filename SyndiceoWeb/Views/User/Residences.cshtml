@model IEnumerable<Syndiceo.Data.Models.Apartment>

@{
    ViewData["Title"] = "Моите имоти";
}

<div class="container py-5">
    <div class="row g-4">
        <div class="col-lg-8">
            <h3 class="fw-bold mb-4">🏠 Моите апартаменти</h3>

            @if (!Model.Any())
            {
                <div class="card border-0 shadow-sm p-5 text-center bg-light">
                    <div class="mb-3" style="font-size: 50px;">🏢</div>
                    <h5 class="text-muted">Все още нямате свързани апартаменти.</h5>
                    <p class="small text-muted">Изберете вашия апартамент от формата вдясно, за да започнете.</p>
                </div>
            }
            else
            {
                <div class="row g-3">
                    @foreach (var apt in Model)
                    {
                        <div class="col-md-6">
                            <div class="card border-0 shadow-sm h-100">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <h5 class="fw-bold mb-0">Апартамент @apt.ApartmentNumber</h5>
                                        @if (apt.IsConfirmed)
                                        {
                                            <span class="badge bg-success-subtle text-success border border-success">Потвърден</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning-subtle text-warning border border-warning">Чака одобрение</span>
                                        }
                                    </div>
                                    <p class="text-muted small mb-1">
                                        📍 ул. @apt.Entrance?.Block?.Address?.Street № @apt.Entrance?.Block?.BlockName,
                                        вх. @apt.Entrance?.EntranceName, ап. @apt.ApartmentNumber
                                    </p>
                                    
                                    @if (apt.IsConfirmed)
                                    {
                                        <div class="mt-3 pt-3 border-top">
                                            <a asp-action="ApartmentTaxes" asp-route-apartmentId="@apt.ApartmentId"
                                               class="btn btn-sm btn-primary w-100">Виж такси и дългове</a>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-lg p-4 sticky-top" style="top: 2rem;">
                <h5 class="fw-bold mb-3">Заяви достъп до имот</h5>
                <p class="text-muted small mb-4">Намерете вашия апартамент в списъка, за да го добавите към профила си.</p>
                
                <form asp-action="RequestApartment" method="post">
                    <div class="mb-4">
                        <label class="form-label small fw-bold">Изберете адрес и апартамент</label>
                        <select name="apartmentId" class="form-select shadow-sm" required>
                            <option value="">-- Избери от наличните --</option>
                            @foreach (var item in ViewBag.AvailableApartments)
                            {
                                <option value="@item.Id">@item.Text</option>
                            }
                        </select>
                    </div>
                    
                    <button type="submit" class="btn btn-dark w-100 shadow-sm py-2">
                        <i class="bi bi-plus-lg"></i> Изпрати заявка
                    </button>
                </form>
                
                <div class="mt-4 p-3 bg-light rounded">
                    <small class="text-muted">
                        <i class="bi bi-info-circle me-1"></i>
                        Ако вашият апартамент не е в списъка, свържете се с домоуправителя.
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>