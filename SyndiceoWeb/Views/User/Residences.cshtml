@model IEnumerable<Syndiceo.Data.Models.Apartment>
@{
    ViewData["Title"] = "Моите имоти";
}

<style>
    .property-card {
        border-radius: 20px;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        border: 1px solid #E2E8F0;
        background: white;
    }
    .property-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 12px 20px rgba(44, 82, 130, 0.08) !important;
        border-color: #2C5282;
    }
    .request-sidebar {
        border-radius: 24px;
        background: #F8FAFC;
        border: 1px solid #E2E8F0;
    }
    .status-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        display: inline-block;
        margin-right: 6px;
    }
    .address-box {
        background: #F1F5F9;
        border-radius: 12px;
        padding: 12px;
        font-size: 0.85rem;
    }
</style>

<div class="container py-5">
    <div class="row g-5">
        
       <div class="col-lg-8">
    <div class="d-flex justify-content-between align-items-center mb-4">
        
        <div class="d-flex align-items-center">
            <div class="bg-primary bg-opacity-10 p-2 rounded-3 me-3 text-primary">
                <i class="bi bi-houses-fill fs-4"></i>
            </div>
            <h3 class="fw-bold mb-0 text-dark">Моите апартаменти</h3>
        </div>

        <a asp-controller="Home" asp-action="Index" class="btn btn-link btn-sm text-decoration-none fw-bold text-muted p-0">
            <i class="bi bi-arrow-left me-1"></i> Назад
        </a>
            </div>

            @if (!Model.Any())
            {
                <div class="card border-0 shadow-sm p-5 text-center bg-white" style="border-radius: 24px;">
                    <div class="mb-4" style="font-size: 60px; opacity: 0.5;">🏢</div>
                    <h5 class="fw-bold text-dark">Все още нямате свързани имоти</h5>
                    <p class="text-muted mx-auto" style="max-width: 400px;">
                        Използвайте формата вдясно, за да намерите вашия адрес и да изпратите заявка за достъп.
                    </p>
                </div>
            }
            else
            {
                <div class="row g-4">
                    @foreach (var apt in Model)
                    {
                        <div class="col-md-6">
                            <div class="card property-card h-100 shadow-sm overflow-hidden">
                                <div class="card-body p-4">
                                    <div class="d-flex justify-content-between align-items-start mb-3">
                                        <div>
                                            <h5 class="fw-bold mb-0 text-dark">Апартамент @apt.ApartmentNumber</h5>
                                            <small class="text-muted">ID: #@apt.ApartmentId.ToString().PadLeft(4, '0')</small>
                                        </div>
                                        @if (apt.IsConfirmed)
                                        {
                                            <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-3 py-2 rounded-pill fw-bold" style="font-size: 0.7rem;">
                                                <span class="status-dot bg-success"></span> АКТИВЕН
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning bg-opacity-10 text-warning border border-warning border-opacity-25 px-3 py-2 rounded-pill fw-bold" style="font-size: 0.7rem;">
                                                <span class="status-dot bg-warning"></span> ЧАКАЩ
                                            </span>
                                        }
                                    </div>

                                    <div class="address-box mb-3 text-muted">
                                        <i class="bi bi-geo-alt-fill me-1 text-primary"></i>
                                        ул. @apt.Entrance?.Block?.Address?.Street № @apt.Entrance?.Block?.BlockName, 
                                        вх. @apt.Entrance?.EntranceName
                                    </div>
                                    
                                    @if (apt.IsConfirmed)
                                    {
                                        <div class="mt-auto pt-3">
                                            <a asp-action="ApartmentTaxes" asp-route-apartmentId="@apt.ApartmentId"
                                               class="btn btn-primary w-100 py-2 fw-bold shadow-none" style="border-radius: 12px;">
                                                <i class="bi bi-wallet2 me-2"></i> Провери такси
                                            </a>
                                        </div>
                                         <div class="mt-auto pt-3">
                                            <a asp-action="ApartmentHistory" asp-route-apartmentId="@apt.ApartmentId"
                                               class="btn btn-primary w-100 py-2 fw-bold shadow-none" style="border-radius: 12px;">
                                                <i class="bi bi-wallet2 me-2"></i> История на плащанията
                                            </a>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="alert alert-light border-0 mb-0 py-2 text-center small text-muted">
                                            <i class="bi bi-hourglass-split me-1"></i> Очаквайте потвърждение
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <div class="col-lg-4">
            <div class="card request-sidebar shadow-sm p-4 sticky-top" style="top: 2rem; border-radius: 24px;">
                <h5 class="fw-bold mb-2">Заяви нов имот</h5>
                <p class="text-muted small mb-4">Изберете вашия адрес от падащото меню, за да изпратите заявка за валидация до домоуправителя.</p>
                
                <form asp-action="RequestApartment" method="post">
                    <div class="mb-4">
                        <label class="form-label small fw-bold text-uppercase opacity-75" style="letter-spacing: 0.5px;">Налични обекти</label>
                        <select name="apartmentId" class="form-select border-0 shadow-sm py-3 px-3" 
                                style="border-radius: 12px; background-color: white;" required>
                            <option value="">-- Избери адрес --</option>
                            @foreach (var item in ViewBag.AvailableApartments)
                            {
                                <option value="@item.Id">@item.Text</option>
                            }
                        </select>
                    </div>
                    
                    <button type="submit" class="btn btn-dark w-100 py-3 fw-bold shadow-sm" style="border-radius: 12px;">
                        <i class="bi bi-plus-circle-fill me-2"></i> Изпрати заявка
                    </button>
                </form>
                
                <div class="mt-5 p-3 rounded-4" style="background: rgba(44, 82, 130, 0.05); border: 1px dashed #2C5282;">
                    <div class="d-flex">
                        <i class="bi bi-info-circle-fill text-primary me-2"></i>
                        <small class="text-muted" style="line-height: 1.4;">
                            Вашата заявка ще бъде прегледана от администратор в рамките на 24 часа.
                        </small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>