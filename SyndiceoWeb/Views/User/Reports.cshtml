@model IEnumerable<Syndiceo.Data.Models.Report>
@{
    ViewData["Title"] = "Моите сигнали";
}

<style>
    .report-form-card {
        border-radius: 20px;
        position: sticky;
        top: 100px;
    }
    .status-pill-user {
        font-size: 0.7rem;
        font-weight: 700;
        padding: 0.4rem 0.8rem;
        border-radius: 50px;
        text-transform: uppercase;
    }
    .report-item {
        border-radius: 16px;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        border: 1px solid #E2E8F0;
    }
    .report-item:hover {
        transform: translateX(5px);
        border-color: #2C5282;
    }
    .step-number {
        width: 24px;
        height: 24px;
        background: #2C5282;
        color: white;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.75rem;
        margin-right: 8px;
    }
</style>

<div class="container py-4">
    
<div class="mb-4"> 
    <div class="d-flex justify-content-between align-items-center">
            <div>
                <h2 class="fw-bold mb-1" style="color: #2D3748;">🚩 Технически сигнали</h2>
                <p class="text-muted mb-0">Съобщете за проблем в общите части или проследете вашите заявки.</p>
            </div>
            
            <a asp-controller="Home" asp-action="Index" class="btn btn-link btn-sm text-decoration-none fw-bold text-muted p-0">
                <i class="bi bi-arrow-left me-1"></i> Назад
            </a>
        </div>
    </div>

    <div class="row g-5">
        <div class="col-lg-5">
            <div class="card report-form-card border-0 shadow-sm p-4 bg-white">
                <div class="d-flex align-items-center mb-4">
                    <div class="bg-primary bg-opacity-10 p-3 rounded-3 me-3 text-primary">
                        <i class="bi bi-megaphone-fill fs-4"></i>
                    </div>
                    <h4 class="fw-bold mb-0">Нов сигнал</h4>
                </div>
                
                <form asp-action="SubmitReport" method="post">
                    <div class="mb-4">
                        <label class="form-label small fw-bold text-uppercase opacity-75">
                            <span class="step-number">1</span> Изберете локация
                        </label>
                        <select name="entranceId" class="form-select form-control shadow-none" required>
                            @foreach (var ent in ViewBag.MyEntrances)
                            {
                                <option value="@ent.EntranceId">Вход @ent.EntranceName</option>
                            }
                        </select>
                    </div>

                    <div class="mb-4">
                        <label class="form-label small fw-bold text-uppercase opacity-75">
                            <span class="step-number">2</span> Тема на проблема
                        </label>
                        <input type="text" name="title" class="form-control shadow-none" 
                               placeholder="напр. Неработещо осветление" required />
                    </div>

                    <div class="mb-4">
                        <label class="form-label small fw-bold text-uppercase opacity-75">
                            <span class="step-number">3</span> Детайлно описание
                        </label>
                        <textarea name="description" class="form-control shadow-none" rows="4" 
                                  placeholder="Опишете проблема колкото се може по-точно..." required></textarea>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-3 fw-bold shadow-sm" style="border-radius: 12px;">
                        <i class="bi bi-send-fill me-2"></i> Изпрати сигнала
                    </button>
                </form>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="fw-bold mb-0">Активност и история</h5>
                <span class="badge bg-light text-muted border px-3 py-2 rounded-pill">
                    Всички: @Model.Count()
                </span>
            </div>
            
            @if (!Model.Any())
            {
                <div class="text-center py-5 bg-white rounded-4 shadow-sm border border-dashed">
                    <div class="display-1 text-light mb-3">🍃</div>
                    <h5 class="text-muted">Все още нямате подадени сигнали.</h5>
                    <p class="small text-muted px-4">Когато подадете сигнал, той ще се появи тук с текущия си статус.</p>
                </div>
            }
            
            @foreach (var report in Model)
            {
                <div class="card report-item shadow-sm mb-3 bg-white border-0">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div class="flex-grow-1">
                                <div class="d-flex align-items-center flex-wrap gap-2 mb-1">
                                    <h5 class="fw-bold m-0 text-dark">@report.Title</h5>
                                    
                                    @if (report.isEdited)
                                    {
                                        <span class="badge rounded-pill bg-light text-muted border-0 fw-normal" 
                                              style="font-size: 0.65rem; letter-spacing: 0.5px; padding: 0.4rem 0.6rem;">
                                            <i class="bi bi-pencil-fill me-1" style="font-size: 0.6rem;"></i> РЕДАКТИРАН
                                        </span>
                                    }
                                </div>
                                
                                <div class="d-flex align-items-center gap-3">
                                    <span class="text-muted small">
                                        <i class="bi bi-calendar3 me-1"></i> @report.CreatedAt.ToString("dd MMM yyyy")
                                    </span>
                                    <span class="text-muted small">
                                        <i class="bi bi-geo-alt-fill me-1"></i> Вход @report.Entrance.EntranceName
                                    </span>
                                </div>
                            </div>

                            <div class="d-flex flex-column align-items-end gap-2">
                                @if (report.IsResolved)
                                {
                                    <span class="status-pill-user bg-success bg-opacity-10 text-success border border-success border-opacity-25">
                                        <i class="bi bi-check-circle-fill me-1"></i> Решен
                                    </span>
                                }
                                else
                                {
                                    <span class="status-pill-user bg-warning bg-opacity-10 text-warning border border-warning border-opacity-25">
                                        <i class="bi bi-clock-history me-1"></i> В процес
                                    </span>
                                    
                                    <button type="button" 
                                            class="btn btn-sm btn-outline-primary rounded-pill px-3 fw-bold" 
                                            onclick="openEditModal('@report.Id', '@Html.Raw(report.Title.Replace("'", "\\'"))', '@Html.Raw(report.Description.Replace("'", "\\'"))', '@report.EntranceId')">
                                        <i class="bi bi-pencil-square me-1"></i> Редактирай
                                    </button>
                                }
                            </div>
                        </div>
                        
                        <div class="p-3 bg-light rounded-4 text-muted small" style="word-break: break-word; border: 1px solid #edf2f7;">
                            @report.Description
                        </div>
                    </div>
                </div>
            }
       
        </div>
    </div>
</div>

<div id="customEditModal" style="display:none; position:fixed; inset:0; z-index:9999; background:rgba(0,0,0,0.7); align-items:center; justify-content:center;">
    <div style="background:white; width:90%; max-width:500px; border-radius:24px; padding:30px; position:relative; box-shadow: 0 20px 50px rgba(0,0,0,0.3);">
        <h4 class="fw-bold mb-4">Редактиране</h4>
        
        <form asp-action="EditReport" method="post">
            <input type="hidden" name="reportId" id="editReportId" />
            
            <div class="mb-3">
                <label class="small fw-bold text-uppercase opacity-50">Локация</label>
                <select name="entranceId" id="editEntranceId" class="form-select bg-light border-0 p-3" style="border-radius:12px;" required>
                    @foreach (var ent in ViewBag.MyEntrances)
                    {
                        <option value="@ent.EntranceId">Вход @ent.EntranceName</option>
                    }
                </select>
            </div>

            <div class="mb-3">
                <label class="small fw-bold text-uppercase opacity-50">Тема</label>
                <input type="text" name="title" id="editTitle" class="form-control bg-light border-0 p-3" style="border-radius:12px;" required />
            </div>

            <div class="mb-4">
                <label class="small fw-bold text-uppercase opacity-50">Описание</label>
                <textarea name="description" id="editDescription" class="form-control bg-light border-0 p-3" style="border-radius:12px;" rows="4" required></textarea>
            </div>

            <div class="d-flex gap-2">
                <button type="button" class="btn btn-light w-100 rounded-pill fw-bold" onclick="closeCustomModal()">Отказ</button>
                <button type="submit" class="btn btn-primary w-100 rounded-pill fw-bold">Запази</button>
            </div>
        </form>
    </div>
</div>
@section Scripts {
    <script>
        function openEditModal(id, title, description, entranceId) {
            document.getElementById('editReportId').value = id;
            document.getElementById('editTitle').value = title;
            document.getElementById('editDescription').value = description;
            document.getElementById('editEntranceId').value = entranceId;

            const modal = document.getElementById('customEditModal');
            modal.style.display = 'flex';
            

            document.body.style.overflow = 'hidden';
        }

        function closeCustomModal() {
            document.getElementById('customEditModal').style.display = 'none';
            document.body.style.overflow = 'auto';
        }
    </script>
}