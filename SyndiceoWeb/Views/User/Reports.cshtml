@model List<SyndiceoWeb.Controllers.UserController.Report>

@{
    ViewData["Title"] = "Моите сигнали";
}

<div class="container py-5">
    <h2>Моите сигнали</h2>

    @if (Model != null && Model.Any())
    {
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Дата</th>
                    <th>Тип сигнал</th>
                    <th>Описание</th>
                    <th>Статус</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var report in Model)
                {
                    <tr>
                        <td>@report.Date.ToShortDateString()</td>
                        <td>@report.Type</td>
                        <td>@report.Description</td>
                        <td>@report.Status</td>
                        <td>
                            <a asp-controller="User" asp-action="ReportDetails" asp-route-id="@report.Id" class="btn btn-sm btn-primary">
                                Детайли
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p class="text-muted">Все още няма подадени сигнали.</p>
    }

    <a asp-controller="User" asp-action="AddReport" class="btn btn-success mt-3">Добави нов сигнал</a>
</div>