@page
@model ContactModel
@{
    ViewData["Title"] = "Контакти";
}

<div class="container d-flex align-items-center justify-content-center" style="min-height:85vh;">
    <div class="col-lg-6 col-md-8">

        <div class="card border-0 shadow-lg p-4 p-md-5 text-center">

            <div class="mb-4">
                <div class="d-inline-flex align-items-center justify-content-center rounded-circle"
                     style="width:80px;height:80px;background:linear-gradient(135deg,#2C5282,#2B6CB0);font-size:34px;color:white;">
                    📩
                </div>
            </div>

            <h2 class="fw-bold mb-3">Свържете се с нас</h2>

            <p class="text-muted mb-4">
                Ако имате въпроси относно входните такси или профила си,
                можете да се свържете с нас на:
            </p>

            <p class="fw-semibold">
                📧 support@syndiceo.bg
            </p>

            <p class="text-muted small mt-3">
                Ще отговорим в рамките на 1–2 работни дни.
            </p>

        </div>

    </div>
</div>