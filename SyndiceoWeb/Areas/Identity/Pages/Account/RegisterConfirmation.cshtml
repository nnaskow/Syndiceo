@page
@model RegisterConfirmationModel
@{
    ViewData["Title"] = "Регистрацията е почти завършена";
}

<style>
    .confirm-card {
        background: white;
        border-radius: 24px;
        border: 1px solid #E2E8F0;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.05);
        overflow: hidden;
        max-width: 550px;
        margin: 3rem auto;
    }

    .confirm-header {
        background: linear-gradient(135deg, #2C5282 0%, #1A365D 100%);
        color: white;
        padding: 2.5rem;
        text-align: center;
    }

    .status-icon {
        width: 70px;
        height: 70px;
        background: rgba(255, 255, 255, 0.2);
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1.5rem;
        font-size: 2rem;
        backdrop-filter: blur(5px);
    }

    .step-box {
        background: #F8FAFC;
        border-radius: 16px;
        padding: 1.5rem;
        margin-bottom: 1rem;
        border: 1px solid #EDF2F7;
        text-align: left;
        display: flex;
        align-items: flex-start;
    }

    .step-number {
        background: #2C5282;
        color: white;
        width: 28px;
        height: 28px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        margin-right: 15px;
        flex-shrink: 0;
        font-size: 0.9rem;
    }

    .step-text h6 {
        margin-bottom: 4px;
        color: #2D3748;
        font-weight: 700;
    }

    .step-text p {
        margin-bottom: 0;
        font-size: 0.9rem;
        color: #718096;
    }
</style>

<div class="container">
    <div class="confirm-card shadow-lg">
        <div class="confirm-header">
            <div class="status-icon">
                <i class="bi bi-envelope-paper-heart"></i>
            </div>
            <h3 class="fw-bold mb-0">Следващи стъпки</h3>
        </div>

        <div class="p-4 p-md-5">
            <h4 class="text-center text-primary fw-bold mb-4">Успешна регистрация!</h4>
            
            <div class="step-box">
                <div class="step-number">1</div>
                <div class="step-text">
                    <h6>Потвърдете вашия имейл</h6>
                    <p>Изпратихме линк за активиране на <strong>@Model.Email</strong>. Моля, проверете пощата си (и папка Спам).</p>
                </div>
            </div>

            <div class="step-box" style="border-left: 4px solid #ECC94B;">
                <div class="step-number" style="background: #D69E2E;">2</div>
                <div class="step-text">
                    <h6>Одобрение от домоуправител</h6>
                    <p>След потвърждение на имейла, вашият домоуправител трябва да одобри достъпа ви до етажната собственост.</p>
                </div>
            </div>

            <div class="text-center mt-4 pt-3">
                <p class="small text-muted mb-4">
                    Ще получите известие по имейл веднага щом профилът ви бъде одобрен.
                </p>
                
                <a href="/" class="btn btn-outline-primary rounded-pill px-4">
                    <i class="bi bi-house-door me-2"></i>Към началната страница
                </a>
            </div>
        </div>
    </div>
</div>