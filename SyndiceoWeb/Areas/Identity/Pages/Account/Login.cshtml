@page
@model LoginModel

@{
    ViewData["Title"] = "Вход";
}
<style>
    .input-group:focus-within .form-control,
    .input-group:focus-within .btn {
        border-color: #86b7fe !important; 
    }

    .toggle-password:hover {
        color: #2C5282 !important;
        background-color: transparent !important;
    }

    .toggle-password:focus {
        box-shadow: none !important;
    }
</style>
<div class="container d-flex align-items-center justify-content-center" style="min-height:85vh;">
    <div class="col-lg-5 col-md-7">

        <div class="card border-0 shadow-lg p-4 p-md-5 text-center">

            <div class="mb-4">
                <div class="d-inline-flex align-items-center justify-content-center rounded-circle"
                     style="width:80px;height:80px;background:linear-gradient(135deg,#2C5282,#2B6CB0);font-size:36px;">
                    🔐
                </div>
            </div>

            <h2 class="fw-bold mb-2">Добре дошли!</h2>
            <p class="text-muted mb-4">
                Влезте в профила си, за да продължите.
            </p>

            <form id="account" method="post" class="text-start">

                <div asp-validation-summary="ModelOnly"
                     class="text-danger small mb-3"
                     role="alert">
                </div>

                <div class="mb-3">
                    <label asp-for="Input.Email" class="form-label fw-semibold">Имейл</label>
                    <input asp-for="Input.Email"
                           class="form-control form-control-lg"
                           autocomplete="username"
                           placeholder="ivan@abv.bg" />
                    <span asp-validation-for="Input.Email"
                          class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.Password" class="form-label fw-semibold">Парола</label>
                    <div class="input-group">
                        <input asp-for="Input.Password"
                               type="password"
                               class="form-control form-control-lg password-input"
                               autocomplete="current-password"
                               placeholder="••••••••"
                               style="border-right: none;" />
                        <button class="btn btn-outline-secondary toggle-password"
                                type="button"
                                style="border-left: none; background: #fff; border-color: #dee2e6;">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                </div>

                <div class="form-check mb-4">
                    <input class="form-check-input"
                           asp-for="Input.RememberMe" />
                    <label class="form-check-label"
                           asp-for="Input.RememberMe">
                        Запомни ме
                    </label>
                </div>

                <button id="login-submit"
                        type="submit"
                        class="btn btn-primary btn-lg w-100 mb-3">
                    Вход
                </button>

                <div class="text-center small">

                    <div class="mb-2">
                        <a id="forgot-password"
                           asp-page="./ForgotPassword"
                           class="text-decoration-none">
                            Забравили сте паролата си?
                        </a>
                    </div>

                    <div class="mb-2">
                        <a asp-page="./Register"
                           asp-route-returnUrl="@Model.ReturnUrl"
                           class="text-decoration-none">
                            Нямате профил? Регистрирайте се
                        </a>
                    </div>

                </div>

            </form>

        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.querySelector('.toggle-password').addEventListener('click', function (e) {
            const passwordInput = this.parentElement.querySelector('.password-input');
            const icon = this.querySelector('i');

            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                icon.classList.remove('bi-eye');
                icon.classList.add('bi-eye-slash');
            } else {
                passwordInput.type = 'password';
                icon.classList.remove('bi-eye-slash');
                icon.classList.add('bi-eye');
            }
        });
    </script>
}