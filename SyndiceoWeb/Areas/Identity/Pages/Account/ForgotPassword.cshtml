@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Възстановяване на парола";
}

<div class="container d-flex align-items-center justify-content-center" style="min-height:70vh;">
    <div class="col-lg-5 col-md-7">

        <div class="card border-0 shadow-lg p-4 p-md-5 text-center">

            <!-- Icon -->
            <div class="mb-4">
                <div class="d-inline-flex align-items-center justify-content-center rounded-circle"
                     style="width:70px;height:70px;background:linear-gradient(135deg,#2C5282,#2B6CB0);font-size:32px;">
                    🔑
                </div>
            </div>

            <h2 class="fw-bold mb-2">Забравена парола?</h2>
            <p class="text-muted mb-4">
                Няма проблем. Въведете имейла си и ще ви изпратим инструкции.
            </p>

            <form method="post" class="text-start">

                <div asp-validation-summary="ModelOnly"
                     class="text-danger small mb-3"
                     role="alert">
                </div>

                <div class="mb-4">
                    <label asp-for="Input.Email" class="form-label fw-semibold"></label>
                    <input asp-for="Input.Email"
                           class="form-control form-control-lg"
                           autocomplete="username"
                           placeholder="ivan@abv.bg" />
                    <span asp-validation-for="Input.Email"
                          class="text-danger small"></span>
                </div>

                <button type="submit"
                        class="btn btn-primary btn-lg w-100 mb-3">
                    Изпрати инструкции
                </button>

                <div class="text-center">
                    <a asp-area="Identity"
                       asp-page="/Account/Login"
                       class="small text-decoration-none">
                        ← Обратно към вход
                    </a>
                </div>

            </form>

        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}