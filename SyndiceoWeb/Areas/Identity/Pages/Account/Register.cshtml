@page
@model RegisterModel
@{
    ViewData["Title"] = "Създаване на акаунт";
}

<style>
    .input-group .btn-outline-secondary {
        border-color: #dee2e6; /* Същият цвят като на полето */
        background: white;
    }
    
    /* Премахваме синия контур на бутона, за да изглежда по-добре */
    .toggle-password:focus {
        box-shadow: none;
    }

    .form-control-lg {
        border-right: none; /* За да се слее с бутона */
    }
</style>
<div class="container d-flex align-items-center justify-content-center" style="min-height:85vh;">
    <div class="col-lg-5 col-md-7">

        <div class="card border-0 shadow-lg p-4 p-md-5 text-center">

            <div class="mb-4">
                <div class="d-inline-flex align-items-center justify-content-center rounded-circle"
                     style="width:80px;height:80px;background:linear-gradient(135deg,#2C5282,#2B6CB0);font-size:36px;">
                    👤
                </div>
            </div>

            <h2 class="fw-bold mb-2">Регистрация</h2>
            <p class="text-muted mb-4">
                Създайте нов акаунт и започнете да управлявате входните си такси.
            </p>

            <form id="registerForm"
                  asp-route-returnUrl="@Model.ReturnUrl"
                  method="post"
                  class="text-start"
                  novalidate>

                <div asp-validation-summary="ModelOnly"
                     class="text-danger small mb-3"
                     role="alert">
                </div>

                <div class="mb-3">
                    <label asp-for="Input.FirstName" class="form-label fw-semibold">Вашето име</label>
                    <input asp-for="Input.FirstName"
                           class="form-control form-control-lg"
                           autocomplete="name"
                           placeholder="Иван" />
                    <span asp-validation-for="Input.FirstName"
                          class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.LastName" class="form-label fw-semibold">Фамилия</label>
                    <input asp-for="Input.LastName"
                           class="form-control form-control-lg"
                           placeholder="Петров" />
                    <span asp-validation-for="Input.LastName"
                          class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.Email" class="form-label fw-semibold">Имейл адрес</label>
                    <input asp-for="Input.Email"
                           class="form-control form-control-lg"
                           autocomplete="username"
                           placeholder="ivan@abv.bg" />
                    <span asp-validation-for="Input.Email"
                          class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.Password" class="form-label fw-semibold">Парола</label>
                    <div class="input-group">
                        <input asp-for="Input.Password"
                               type="password"
                               class="form-control form-control-lg password-input"
                               autocomplete="new-password"
                               placeholder="••••••••" />
                        <button class="btn btn-outline-secondary toggle-password" type="button">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Input.ConfirmPassword" class="form-label fw-semibold">
                        Потвърдете паролата
                    </label>
                    <div class="input-group">
                        <input asp-for="Input.ConfirmPassword"
                               type="password"
                               class="form-control form-control-lg password-input"
                               autocomplete="new-password"
                               placeholder="••••••••" />
                        <button class="btn btn-outline-secondary toggle-password" type="button">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                </div>
                <button id="registerSubmit"
                        type="submit"
                        class="btn btn-primary btn-lg w-100 mb-3">
                    Създай акаунт
                </button>

                <div class="text-center">
                    <span class="small text-muted">
                        Вече имате акаунт?
                        <a asp-page="/Account/Login" class="text-decoration-none">
                            Вход
                        </a>
                    </span>
                </div>

            </form>

        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    
    <script>
        document.querySelectorAll('.toggle-password').forEach(button => {
            button.addEventListener('click', function() {
                const input = this.parentElement.querySelector('.password-input');
                const icon = this.querySelector('i');
                
                if (input.type === "password") {
                    input.type = "text";
                    icon.classList.remove('bi-eye');
                    icon.classList.add('bi-eye-slash');
                } else {
                    input.type = "password";
                    icon.classList.remove('bi-eye-slash');
                    icon.classList.add('bi-eye');
                }
            });
        });
    </script>
}
