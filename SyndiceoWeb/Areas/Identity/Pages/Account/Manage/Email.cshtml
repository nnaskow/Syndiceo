@page
@model EmailModel
@{
    ViewData["Title"] = "Имейл настройки";
    ViewData["ActivePage"] = ManageNavPages.Email;
}

<style>
    .profile-card {
        background: white;
        border-radius: 24px;
        border: 1px solid #E2E8F0;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.05);
        overflow: hidden;
    }

    .profile-header {
        background: linear-gradient(135deg, #2C5282 0%, #1A365D 100%);
        color: white;
        padding: 1.5rem;
        text-align: center;
    }

    .custom-input {
        border-radius: 12px;
        border: 1px solid #E2E8F0;
        padding: 0.75rem 1rem;
        transition: all 0.2s;
    }

        .custom-input:focus {
            border-color: #2C5282;
            box-shadow: 0 0 0 3px rgba(44, 82, 130, 0.1);
        }

    .input-label {
        font-weight: 600;
        color: #4A5568;
        margin-bottom: 0.5rem;
        font-size: 0.9rem;
    }

    .btn-syndiceo {
        background: #2C5282;
        color: white;
        border-radius: 12px;
        padding: 0.8rem;
        font-weight: 700;
        border: none;
        transition: transform 0.2s, background 0.2s;
    }

        .btn-syndiceo:hover {
            background: #1A365D;
            transform: translateY(-1px);
            color: white;
        }

    .verified-badge {
        background-color: #C6F6D5;
        color: #22543D;
        font-size: 0.75rem;
        padding: 0.2rem 0.6rem;
        border-radius: 20px;
        font-weight: 700;
    }
</style>

<partial name="_StatusMessage" for="StatusMessage" />

<div class="row justify-content-center">
    <div class="col-md-12">
        <div class="profile-card shadow-sm">
            <div class="profile-header">
                <div class="bg-white text-primary rounded-circle mx-auto mb-2 d-flex align-items-center justify-content-center shadow-sm" style="width: 50px; height: 50px;">
                    <i class="bi bi-envelope-paper-fill fs-4"></i>
                </div>
                <h5 class="mb-0 fw-bold">Комуникация</h5>
                <p class="small opacity-75 mb-0">Управлявайте вашия електронен адрес</p>
            </div>

            <div class="p-4 p-md-5">
                <form id="email-form" method="post">
                    <div asp-validation-summary="All" class="text-danger mb-3" role="alert"></div>

                    <div class="row g-4">
                        <div class="col-12">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <label asp-for="Email" class="input-label mb-0">Текущ имейл</label>
                                @if (Model.IsEmailConfirmed)
                                {
                                    <span class="verified-badge"><i class="bi bi-patch-check-fill me-1"></i> Потвърден</span>
                                }
                            </div>
                            
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0" style="border-radius: 12px 0 0 12px;">
                                    <i class="bi bi-envelope-at text-muted"></i>
                                </span>
                                <input asp-for="Email" class="form-control custom-input border-start-0"
                                       style="border-radius: 0 12px 12px 0; background-color: #f8fafc;" disabled />
                            </div>

                            @if (!Model.IsEmailConfirmed)
                            {
                                <div class="mt-2 text-end">
                                    <button id="email-verification" type="submit" asp-page-handler="SendVerificationEmail"
                                            class="btn btn-link btn-sm text-decoration-none fw-bold p-0">
                                        <i class="bi bi-send me-1"></i> Изпрати имейл за потвърждение
                                    </button>
                                </div>
                            }
                        </div>

                        <hr class="my-2 opacity-50">

                        <div class="col-12">
                            <label asp-for="Input.NewEmail" class="input-label">Нов имейл адрес</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0" style="border-radius: 12px 0 0 12px;">
                                    <i class="bi bi-plus-circle text-primary"></i>
                                </span>
                                <input asp-for="Input.NewEmail" class="form-control custom-input border-start-0"
                                       style="border-radius: 0 12px 12px 0;" placeholder="Въведете новия адрес..." />
                            </div>
                            <span asp-validation-for="Input.NewEmail" class="text-danger small"></span>
                        </div>

                        <div class="col-12 mt-4">
                            <button type="submit" asp-page-handler="ChangeEmail" class="btn btn-syndiceo w-100 shadow-sm">
                                <i class="bi bi-envelope-check me-2"></i> Промени имейл адреса
                            </button>
                        </div>
                    </div>
                </form>

                <div class="text-center mt-4">
                    <p class="text-muted" style="font-size: 0.8rem;">
                        <i class="bi bi-shield-exclamation me-1"></i>
                        Ще трябва да потвърдите новия адрес, преди той да стане активен.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}