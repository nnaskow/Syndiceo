@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Сигурност";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<style>
    .profile-card {
        background: white;
        border-radius: 24px;
        border: 1px solid #E2E8F0;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.05);
        overflow: hidden;
    }

    .profile-header {
        background: linear-gradient(135deg, #2C5282 0%, #1A365D 100%);
        color: white;
        padding: 1.5rem;
        text-align: center;
    }

    .custom-input {
        border-radius: 12px;
        border: 1px solid #E2E8F0;
        padding: 0.75rem 1rem;
        transition: all 0.2s;
    }

        .custom-input:focus {
            border-color: #2C5282;
            box-shadow: 0 0 0 3px rgba(44, 82, 130, 0.1);
        }

    .input-label {
        font-weight: 600;
        color: #4A5568;
        margin-bottom: 0.5rem;
        font-size: 0.9rem;
    }

    .btn-syndiceo {
        background: #2C5282;
        color: white;
        border-radius: 12px;
        padding: 0.8rem;
        font-weight: 700;
        border: none;
        transition: transform 0.2s, background 0.2s;
    }

        .btn-syndiceo:hover {
            background: #1A365D;
            transform: translateY(-1px);
            color: white;
        }
</style>

<partial name="_StatusMessage" for="StatusMessage" />

<div class="row justify-content-center">
    <div class="col-md-12">
        <div class="profile-card shadow-sm">
            <div class="profile-header">
                <div class="bg-white text-primary rounded-circle mx-auto mb-2 d-flex align-items-center justify-content-center shadow-sm" style="width: 50px; height: 50px;">
                    <i class="bi bi-shield-lock-fill fs-4"></i>
                </div>
                <h5 class="mb-0 fw-bold">Промяна на парола</h5>
                <p class="small opacity-75 mb-0">Използвайте силна парола за по-добра защита</p>
            </div>

            <div class="p-4 p-md-5">
                <form id="change-password-form" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

                    <div class="row g-4">
                        <div class="col-12">
                            <label asp-for="Input.OldPassword" class="input-label">Текуща парола</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0" style="border-radius: 12px 0 0 12px;">
                                    <i class="bi bi-key text-muted"></i>
                                </span>
                                <input asp-for="Input.OldPassword" class="form-control custom-input border-start-0"
                                       style="border-radius: 0 12px 12px 0;" placeholder="Въведете старата парола" />
                            </div>
                            <span asp-validation-for="Input.OldPassword" class="text-danger small"></span>
                        </div>

                        <hr class="my-2 opacity-50">

                        <div class="col-md-6">
                            <label asp-for="Input.NewPassword" class="input-label">Нова парола</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0" style="border-radius: 12px 0 0 12px;">
                                    <i class="bi bi-lock text-primary"></i>
                                </span>
                                <input asp-for="Input.NewPassword" class="form-control custom-input border-start-0"
                                       style="border-radius: 0 12px 12px 0;" placeholder="Минимум 6 символа" />
                            </div>
                            <span asp-validation-for="Input.NewPassword" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Input.ConfirmPassword" class="input-label">Потвърдете паролата</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0" style="border-radius: 12px 0 0 12px;">
                                    <i class="bi bi-lock-fill text-primary"></i>
                                </span>
                                <input asp-for="Input.ConfirmPassword" class="form-control custom-input border-start-0"
                                       style="border-radius: 0 12px 12px 0;" placeholder="Повторете новата парола" />
                            </div>
                            <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                        </div>

                        <div class="col-12 mt-4">
                            <button type="submit" class="btn btn-syndiceo w-100 shadow-sm">
                                <i class="bi bi-arrow-repeat me-2"></i> Обнови паролата
                            </button>
                        </div>
                    </div>
                </form>

                <div class="text-center mt-4">
                    <p class="text-muted" style="font-size: 0.8rem;">
                        <i class="bi bi-info-square me-1"></i>
                        След промяна ще останете вписани в текущата сесия.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}