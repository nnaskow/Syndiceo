@page
@model IndexModel
@{
    ViewData["Title"] = "Профил";
    ViewData["ActivePage"] = ManageNavPages.Index;
}

<partial name="_StatusMessage" for="StatusMessage" />

<div class="row">
    <div class="col-md-7">
        <div class="card shadow-sm p-4" style="border-radius:0.75rem; background:local;">

            <h3 class="mb-4 fw-bold text-center">@ViewData["Title"]</h3>

            <form id="profile-form" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

                <div class="form-floating mb-3">
                    <input asp-for="Username" class="form-control" placeholder="Потребителско име" disabled />
                    <label asp-for="Username">Потребителско име</label>
                </div>

                <div class="form-floating mb-4">
                    <input asp-for="Input.PhoneNumber" class="form-control" placeholder="Телефонен номер" />
                    <label asp-for="Input.PhoneNumber">Телефонен номер</label>
                    <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
                </div>

                <button type="submit" id="update-profile-button" class="btn btn-primary btn-lg w-100 mb-3" ">
                    Запази
                </button>
            </form>

            <p class="text-muted small mt-3 text-center">
                Промените се запазват веднага след редакция.
            </p>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}