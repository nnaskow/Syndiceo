@page
@model IndexModel
@{
    ViewData["Title"] = "Моят Профил";
    ViewData["ActivePage"] = ManageNavPages.Index;
}

<style>
    /* Стил за контейнера на формата, подобен на таблиците ти */
    .profile-card {
        background: white;
        border-radius: 24px;
        border: 1px solid #E2E8F0;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.05);
        overflow: hidden;
    }

    .profile-header {
        background: linear-gradient(135deg, #2C5282 0%, #1A365D 100%);
        color: white;
        padding: 1.5rem;
        text-align: center;
    }

    /* Стилизиране на полетата (inputs) */
    .custom-input {
        border-radius: 12px;
        border: 1px solid #E2E8F0;
        padding: 0.75rem 1rem;
        transition: all 0.2s;
    }

        .custom-input:focus {
            border-color: #2C5282;
            box-shadow: 0 0 0 3px rgba(44, 82, 130, 0.1);
        }

    .input-label {
        font-weight: 600;
        color: #4A5568;
        margin-bottom: 0.5rem;
        font-size: 0.9rem;
    }

    /* Бутонът в стила на приложението */
    .btn-syndiceo {
        background: #2C5282;
        color: white;
        border-radius: 12px;
        padding: 0.8rem;
        font-weight: 700;
        border: none;
        transition: transform 0.2s, background 0.2s;
    }

        .btn-syndiceo:hover {
            background: #1A365D;
            transform: translateY(-1px);
            color: white;
        }
</style>

<partial name="_StatusMessage" for="StatusMessage" />

<div class="row justify-content-center">
    <div class="col-md-12">
        <div class="profile-card shadow-sm">
            @* Хедър с икона *@
            <div class="profile-header">
                <div class="bg-white text-primary rounded-circle mx-auto mb-2 d-flex align-items-center justify-content-center shadow-sm" style="width: 50px; height: 50px;">
                    <i class="bi bi-person-badge-fill fs-4"></i>
                </div>
                <h5 class="mb-0 fw-bold">Настройки на профила</h5>
                <p class="small opacity-75 mb-0">Управлявайте личните си данни</p>
            </div>

            <div class="p-4 p-md-5">
                <form id="profile-form" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

                    <div class="row g-3">
                        @* Име *@
                        <div class="col-md-6">
                            <label asp-for="Input.FirstName" class="input-label">Име</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0" style="border-radius: 12px 0 0 12px;">
                                    <i class="bi bi-person text-primary"></i>
                                </span>
                                <input asp-for="Input.FirstName" class="form-control custom-input border-start-0"
                                       style="border-radius: 0 12px 12px 0;" placeholder="Вашето име" />
                            </div>
                            <span asp-validation-for="Input.FirstName" class="text-danger small"></span>
                        </div>

                        @* Фамилия *@
                        <div class="col-md-6">
                            <label asp-for="Input.LastName" class="input-label">Фамилия</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0" style="border-radius: 12px 0 0 12px;">
                                    <i class="bi bi-person-fill text-primary"></i>
                                </span>
                                <input asp-for="Input.LastName" class="form-control custom-input border-start-0"
                                       style="border-radius: 0 12px 12px 0;" placeholder="Вашата фамилия" />
                            </div>
                            <span asp-validation-for="Input.LastName" class="text-danger small"></span>
                        </div>

                        @* Имейл *@
                        <div class="col-12">
                            <label asp-for="Input.Email" class="input-label">Имейл адрес</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0" style="border-radius: 12px 0 0 12px;">
                                    <i class="bi bi-envelope-at text-primary"></i>
                                </span>
                                <input asp-for="Input.Email" class="form-control custom-input border-start-0"
                                       style="border-radius: 0 12px 12px 0;" placeholder="example@mail.com" />
                            </div>
                            <span asp-validation-for="Input.Email" class="text-danger small"></span>
                        </div>

                        @* Потребителско име - само за четене *@
                        <div class="col-12 opacity-75">
                            <label asp-for="Username" class="input-label">Системно потребителско име</label>
                            <input asp-for="Username" class="form-control custom-input bg-light" disabled />
                        </div>

                        @* Бутон за запазване *@
                        <div class="col-12 mt-4">
                            <button type="submit" id="update-profile-button" class="btn btn-syndiceo w-100 shadow-sm">
                                <i class="bi bi-shield-check me-2"></i> Обнови профила
                            </button>
                        </div>
                    </div>
                </form>
                <div class="text-center mt-4">
                    <p class="text-muted" style="font-size: 0.8rem;">
                        <i class="bi bi-info-circle me-1"></i>
                        Системата автоматично обновява информацията след потвърждение.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}