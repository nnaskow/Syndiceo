@inject SignInManager<SyndiceoWebUser> SignInManager
@{
    var hasExternalLogins = (await SignInManager.GetExternalAuthenticationSchemesAsync()).Any();
}

<div class="d-flex flex-column" style="gap:0.5rem;">
    <a class="nav-link @ManageNavPages.IndexNavClass(ViewContext)"
       asp-page="./Index"
       style="padding:0.75rem 1rem; border-radius:0.5rem;
              background:@(ManageNavPages.IndexNavClass(ViewContext) == "active" ? "linear-gradient(135deg,#2C5282,#2B6CB0)" : "#2B6CB0");
              color:white; font-weight:500; text-align:center; transition: all 0.2s;">
        Профил
    </a>

    <a class="nav-link @ManageNavPages.EmailNavClass(ViewContext)"
       asp-page="./Email"
       style="padding:0.75rem 1rem; border-radius:0.5rem;
              background:@(ManageNavPages.EmailNavClass(ViewContext) == "active" ? "linear-gradient(135deg,#2C5282,#2B6CB0)" : "#2B6CB0");
              color:white; font-weight:500; text-align:center; transition: all 0.2s;">
        Имейл
    </a>

    <a class="nav-link @ManageNavPages.ChangePasswordNavClass(ViewContext)"
       asp-page="./ChangePassword"
       style="padding:0.75rem 1rem; border-radius:0.5rem;
              background:@(ManageNavPages.ChangePasswordNavClass(ViewContext) == "active" ? "linear-gradient(135deg,#2C5282,#2B6CB0)" : "#2B6CB0");
              color:white; font-weight:500; text-align:center; transition: all 0.2s;">
        Парола
    </a>

    @if (hasExternalLogins)
    {
        <a class="nav-link @ManageNavPages.ExternalLoginsNavClass(ViewContext)"
           asp-page="./ExternalLogins"
           style="padding:0.75rem 1rem; border-radius:0.5rem;
                      background:@(ManageNavPages.ExternalLoginsNavClass(ViewContext) == "active" ? "linear-gradient(135deg,#2C5282,#2B6CB0)" : "#2B6CB0");
                      color:white; font-weight:500; text-align:center; transition: all 0.2s;">
            Външни логини
        </a>
    }

    <a class="nav-link @ManageNavPages.PersonalDataNavClass(ViewContext)"
       asp-page="./PersonalData"
       style="padding:0.75rem 1rem; border-radius:0.5rem;
              background:@(ManageNavPages.PersonalDataNavClass(ViewContext) == "active" ? "linear-gradient(135deg,#2C5282,#2B6CB0)" : "#2B6CB0");
              color:white; font-weight:500; text-align:center; transition: all 0.2s;">
        Лични данни
    </a>
</div>

<style>
    .nav-link:hover {
        background: linear-gradient(135deg,#2B6CB0,#2C5282);
        text-decoration: none;
        color: white;
    }
</style>