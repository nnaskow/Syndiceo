@inject SignInManager<SyndiceoWebUser> SignInManager
@{
    var hasExternalLogins = (await SignInManager.GetExternalAuthenticationSchemesAsync()).Any();
    
    string IsActive(string navClass) =>
            (navClass?.Contains("active", StringComparison.OrdinalIgnoreCase) ?? false)
            ? "active-nav"
            : "inactive-nav";
}

<style>
    .nav-container {
        gap: 0.75rem;
        padding-right: 1rem;
    }

    .custom-nav-link {
        padding: 0.8rem 1.2rem;
        border-radius: 12px;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        display: flex;
        align-items: center;
        gap: 10px;
        border: 1px solid transparent;
    }

    .active-nav {
        background: linear-gradient(135deg, #2C5282 0%, #1A365D 100%);
        color: white !important;
        box-shadow: 0 4px 12px rgba(44, 82, 130, 0.2);
    }

    .inactive-nav {
        background: #F8FAFC;
        color: #64748B !important;
        border: 1px solid #E2E8F0;
    }

        .inactive-nav:hover {
            background: #EDF2F7;
            color: #2C5282 !important;
            transform: translateX(5px); 
        }

    .nav-icon {
        font-size: 1.1rem;
    }
</style>

<div class="d-flex flex-column nav-container">
    <a class="custom-nav-link @IsActive(ManageNavPages.IndexNavClass(ViewContext))"
           id="profile" asp-page="./Index">
        <i class="bi bi-person-circle nav-icon"></i> Профил
    </a>

    <a class="custom-nav-link @IsActive(ManageNavPages.EmailNavClass(ViewContext))"
           id="email" asp-page="./Email">
        <i class="bi bi-envelope-at nav-icon"></i> Имейл
    </a>

    <a class="custom-nav-link @IsActive(ManageNavPages.ChangePasswordNavClass(ViewContext))"
           id="change-password" asp-page="./ChangePassword">
        <i class="bi bi-shield-lock nav-icon"></i> Парола
    </a>

    @if (hasExternalLogins)
    {
        <a class="custom-nav-link @IsActive(ManageNavPages.ExternalLoginsNavClass(ViewContext))"
               id="external-login" asp-page="./ExternalLogins">
            <i class="bi bi-google nav-icon"></i> Външни входове
        </a>
    }
</div>