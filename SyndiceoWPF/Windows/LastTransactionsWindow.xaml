<Window x:Class="Syndiceo.Windows.LastTransactionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Syndiceo"
        mc:Ignorable="d"
        Title="История на плащанията"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None" 
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Height="420"
        Width="380"
        Topmost="True"
        Closing="Window_Closing">

    <Border Margin="15" CornerRadius="15" Background="White" BorderBrush="#E2E8F0" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Opacity="0.1" ShadowDepth="2" Color="#64748B"/>
        </Border.Effect>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,15">
                <TextBlock Text="💳 Последни плащания"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="#1E293B"
                           HorizontalAlignment="Center"
                           FontFamily="Segoe UI"/>
                <Separator Margin="0,10,0,0" Background="#F1F5F9" Height="1"/>
            </StackPanel>

            <ListView x:Name="TransactionsList"
                      Grid.Row="1"
                      BorderThickness="0"
                      Background="Transparent"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      SelectionMode="Single"
                      Margin="0,5">

                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Margin" Value="0,4"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Background" Value="#F8FAFC"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListViewItem">
                                    <Border x:Name="Bd"
                                            CornerRadius="10"
                                            BorderThickness="1"
                                            BorderBrush="#F1F5F9"
                                            Background="{TemplateBinding Background}"
                                            Padding="10,8">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#F1F5F9"/>
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="#E2E8F0"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#EFF6FF"/>
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="#DBEAFE"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListView.ItemContainerStyle>

                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="💰" FontSize="14" VerticalAlignment="Center" Margin="5,0,10,0"/>

                            <TextBlock Grid.Column="1" 
                                       Text="{Binding Amount, StringFormat='{}{0:N2} лв.'}"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       FontFamily="Segoe UI"
                                       VerticalAlignment="Center"
                                       Foreground="#334155"/>

                            <Button Grid.Column="2"
                                    Width="32"
                                    Height="32"
                                    Content="✕"
                                    FontSize="12"
                                    FontWeight="Bold"
                                    ToolTip="Премахни"
                                    Click="DeleteTransaction_Click"
                                    Cursor="Hand"
                                    Background="Transparent"
                                    Foreground="#94A3B8"
                                    BorderThickness="0">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Foreground" Value="#E74C3C"/>
                                                <Setter Property="Background" Value="#FEE2E2"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="16"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <Button Grid.Row="2"
                    Content="Затвори"
                    Width="140"
                    Height="40"
                    FontSize="14"
                    FontWeight="SemiBold"
                    HorizontalAlignment="Center"
                    Margin="0,15,0,0"
                    Style="{StaticResource MainButtonStyle}"
                    Click="Close_Click"
                    Cursor="Hand"/>
        </Grid>
    </Border>
</Window>