<Window x:Class="Syndiceo.Windows.LastTransactionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Syndiceo"
        mc:Ignorable="d"
        Title="Плащания"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="ToolWindow"
        ShowInTaskbar="False"
        Height="380"
        Width="360"
        MinWidth="320"
        MinHeight="320"
        Background="{StaticResource AppBackground}"
        FontFamily="Calibri"
        Icon="pack://application:,,,/Resources/Ico/logo128.ico"
        Topmost="True"
        Closing="Window_Closing">

    <Border Margin="12" Padding="14" CornerRadius="12" Background="White" BorderBrush="#DDD" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 🔹 Заглавие -->
            <TextBlock Text="Последни плащания"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="#333"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,10"/>

            <!-- 🔹 Списък с плащания -->
            <ListView x:Name="TransactionsList"
                      Grid.Row="1"
                      BorderBrush="#E0E0E0"
                      BorderThickness="1"
                      Margin="0,0,0,12"
                      Background="#FFF"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      SelectionMode="Single">

                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Margin" Value="0,2"/>
                        <Setter Property="Padding" Value="6,4"/>
                        <Setter Property="Background" Value="#FAFAFA"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListViewItem">
                                    <Border x:Name="Bd"
                                            CornerRadius="6"
                                            BorderThickness="1"
                                            BorderBrush="#DDD"
                                            Background="{TemplateBinding Background}">
                                        <ContentPresenter Margin="6,3"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#F3F6FF"/>
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="#C2D2FF"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#E6EEFF"/>
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="#7BA0FF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListView.ItemContainerStyle>

                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- 🔸 Сума -->
                            <TextBlock Text="{Binding Amount, StringFormat='{}{0:F2} лв.'}"
                                       FontSize="16"
                                       FontFamily="Consolas"
                                       VerticalAlignment="Center"
                                       Foreground="#333"
                                       Margin="8,0"/>

                            <!-- 🔸 Бутон за изтриване -->
                            <Button Grid.Column="1"
                                    Width="34"
                                    Height="40"
                                    Margin="6,0,6,0"
                                    FontSize="16"
                                    ToolTip="Премахни плащането"
                                    Click="DeleteTransaction_Click"
                                    Background="#FFF5F5F5"
                                    BorderBrush="#DDD"
                                    BorderThickness="1"
                                    Content="🗑️"
                                    Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource MainButtonStyle}">
                                        <Setter Property="Background" Value="#FFF5F5F5"/>
                                        <Setter Property="Foreground" Value="#444"/>
                                        <Setter Property="BorderBrush" Value="#CCC"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#FFE8E8E8"/>
                                                <Setter Property="BorderBrush" Value="#B0B0B0"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter Property="Background" Value="#FFDDDDDD"/>
                                                <Setter Property="BorderBrush" Value="#999"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- 🔹 Долен бутон -->
            <Button Content="Затвори"
                    Grid.Row="2"
                    Width="130"
                    Height="38"
                    FontSize="15"
                    FontWeight="SemiBold"
                    HorizontalAlignment="Center"
                    Margin="0,5,0,0"
                    Style="{StaticResource MainButtonStyle}"
                    Click="Close_Click"/>
        </Grid>
    </Border>
</Window>
