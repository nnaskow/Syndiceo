<Window x:Class="Syndiceo.Windows.DocumentsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Управление на документи"
        MinWidth="900" MinHeight="600"
        Width="1100" Height="750"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Icon="pack://application:,,,/Resources/Ico/logo256.ico"
        Loaded="Window_Loaded" Background="#F1F5F9">
    <Grid Margin="20">
        <Grid Panel.ZIndex="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="400"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,0,15,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" x:Name="addDocsPanel" 
                        CornerRadius="12" Background="White" Padding="15" Margin="0,0,0,15"
                        BorderBrush="#E2E8F0" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" Opacity="0.05" ShadowDepth="1" Color="#64748B"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="📂 Текущ вход" FontWeight="Bold" FontSize="16" Foreground="#1E293B"/>
                        <Separator Margin="0,10" Background="#F1F5F9"/>

                        <Button x:Name="AddDocumentButton"
                                Style="{StaticResource MainButtonStyle}"
                                Content="➕ Качи нов документ"
                                Height="38" Margin="0,0,0,12"
                                Click="AddDocumentButton_Click"/>

                        <DataGrid x:Name="EntranceDocumentsDataGrid"
                                  Height="180"
                                  AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                                  SelectionChanged="DocumentsDataGrid_SelectionChanged"
                                  RowHeaderWidth="0" GridLinesVisibility="None"
                                  Background="Transparent" BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Име на файл" Binding="{Binding FileName}" Width="*"/>
                                <DataGridTextColumn Header="Дата" Binding="{Binding UploadDate, StringFormat=d}" Width="90"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" CornerRadius="12" Background="White" Padding="15"
                        BorderBrush="#E2E8F0" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" Opacity="0.05" ShadowDepth="1" Color="#64748B"/>
                    </Border.Effect>
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="📑 Всички документи" FontWeight="Bold" FontSize="16" Foreground="#1E293B"/>
                        <Separator DockPanel.Dock="Top" Margin="0,10" Background="#F1F5F9"/>

                        <Button DockPanel.Dock="Bottom" 
                                Style="{StaticResource MainButtonStyle}"
                                Content="📂 Отвори папката"
                                Height="38" Margin="0,10,0,0"
                                Click="OpenAllDocumentsFolder_Click"/>

                        <DataGrid x:Name="AllDocumentsDataGrid"
                                  AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                                  SelectionChanged="DocumentsDataGrid_SelectionChanged"
                                  RowHeaderWidth="0" GridLinesVisibility="None"
                                  Background="Transparent" BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Файл" Binding="{Binding FileName}" Width="*"/>
                                <DataGridTextColumn Header="Адрес" Binding="{Binding FullAddress}" Width="100"/>
                                <DataGridTextColumn Header="Дата" Binding="{Binding UploadDate, StringFormat=d}" Width="85"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </Grid>

            <Border Grid.Column="1" CornerRadius="12" Background="White" Padding="10"
                    BorderBrush="#E2E8F0" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" Opacity="0.05" ShadowDepth="2" Color="#64748B"/>
                </Border.Effect>
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="👁 Преглед на съдържанието" 
                               FontWeight="Bold" FontSize="16" Foreground="#1E293B" Margin="10,5"/>
                    <Separator DockPanel.Dock="Top" Margin="0,10" Background="#F1F5F9"/>

                    <Border Margin="5" Background="#F8FAFC" CornerRadius="8" BorderBrush="#F1F5F9" BorderThickness="1">
                        <ContentControl x:Name="PreviewContent" 
                                        HorizontalAlignment="Stretch" 
                                        VerticalAlignment="Stretch"/>
                    </Border>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>