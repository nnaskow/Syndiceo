<Window x:Class="Syndiceo.Windows.DocumentsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Документи"
        MinWidth="600" MinHeight="400"
        Width="941" Height="704"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Icon="pack://application:,,,/Resources/Ico/logo128.ico"
        FontFamily="Calibri"
        Loaded="Window_Loaded" Background="{StaticResource AppBackground}">

    <Grid Margin="20" Background="{StaticResource AppBackground}">
        <!-- Watermark -->
        <Image Source="/Resources/logo.png"
               Opacity="0.05"
               Stretch="Uniform"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               Panel.ZIndex="0"/>

        <!-- Основно съдържание -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.375*"/>
                <ColumnDefinition Width="1.5*"/>
            </Grid.ColumnDefinitions>

            <!-- ЛЯВА ЧАСТ -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*"/>
                    <RowDefinition Height="3*"/>
                </Grid.RowDefinitions>

                <!-- ГОРЕ: Документи за вход -->
                <Border Grid.Row="0" CornerRadius="10" Padding="15" 
                        BorderBrush="#DDD" BorderThickness="1" Background="Transparent" Margin="0,0,10,10" x:Name="addDocsPanel">
                    <StackPanel>
                        <TextBlock Text="📂 Документи за избрания вход"
                                   FontWeight="Bold" FontSize="18"
                                   HorizontalAlignment="Center" Foreground="#333"/>
                        <Separator Margin="0,10,0,10"/>

                        <Button x:Name="AddDocumentButton"
                                Style="{StaticResource MainButtonStyle}"
                                Content="➕ Добави документ"
                                Width="200" Height="40"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,10"
                                Click="AddDocumentButton_Click"/>

                        <DataGrid x:Name="EntranceDocumentsDataGrid"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  SelectionChanged="DocumentsDataGrid_SelectionChanged"
                                  FontFamily="Calibri"
                                  RowHeaderWidth="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Име" Binding="{Binding FileName}" Width="*"/>
                                <DataGridTextColumn Header="Дата" Binding="{Binding UploadDate, StringFormat=d}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- ДОЛУ: Всички документи -->
                <Border Grid.Row="1" CornerRadius="10" Padding="15" 
                        BorderBrush="#DDD" BorderThickness="1" Background="Transparent" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="📑 Всички документи"
                                   FontWeight="Bold" FontSize="18"
                                   HorizontalAlignment="Center" Foreground="#333"/>
                        <Separator Margin="0,10,0,10"/>

                        <DataGrid x:Name="AllDocumentsDataGrid"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  SelectionChanged="DocumentsDataGrid_SelectionChanged"
                                  FontFamily="Calibri"
                                  RowHeaderWidth="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Име" Binding="{Binding FileName}" Width="*"/>
                                <DataGridTextColumn Header="Вход" Binding="{Binding FullAddress}" Width="150"/>
                                <DataGridTextColumn Header="Дата" Binding="{Binding UploadDate, StringFormat=d}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Button Style="{StaticResource MainButtonStyle}"
                                Content="📂 Отвори папката с документи"
                                Width="239" Height="40"
                                HorizontalAlignment="Center"
                                Margin="0,10,0,0"
                                Click="OpenAllDocumentsFolder_Click"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ДЯСНО: Preview -->
            <Border Grid.Column="1" CornerRadius="10" Padding="15"
                    BorderBrush="#DDD" BorderThickness="1" Background="Transparent" Margin="10,0,0,0">
                <StackPanel>
                    <TextBlock Text="👁 Преглед на документ"
                               FontWeight="Bold" FontSize="18"
                               HorizontalAlignment="Center" Foreground="#333"/>
                    <Separator Margin="0,10,0,10"/>

                    <ContentControl x:Name="PreviewContent"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
