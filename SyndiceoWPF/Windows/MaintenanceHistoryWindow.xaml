<Window x:Class="Syndiceo.Windows.MaintenanceHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Syndiceo"
        mc:Ignorable="d"
        Title="Ремонтни дейности и поддръжка"
        MinWidth="850" MinHeight="500"
        Width="950" Height="550"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Icon="pack://application:,,,/Resources/Ico/logo256.ico"
        Loaded="Window_Loaded" Background="#F8FAFC">

    <Grid Margin="0">
        <Image Source="/Resources/logo.png"
               Opacity="0.03"
               Stretch="Uniform"
               Width="200"
               HorizontalAlignment="Right"
               VerticalAlignment="Bottom"
               Margin="0,0,20,20"
               Panel.ZIndex="0"/>

        <Grid Margin="25" Panel.ZIndex="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" CornerRadius="15" Background="White" Padding="20" Margin="0,0,20,0" 
                    BorderBrush="#E2E8F0" BorderThickness="1" VerticalAlignment="Stretch">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" Opacity="0.05" ShadowDepth="2" Color="#64748B"/>
                </Border.Effect>

                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="🛠️" FontSize="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Нов ремонт" 
                                   FontFamily="Segoe UI" FontWeight="Bold" FontSize="18" 
                                   Foreground="#1E293B" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Separator Margin="0,0,0,20" Background="#F1F5F9" Height="1"/>

                    <Label Content="Описание на дейността:" FontWeight="SemiBold" FontSize="13" Foreground="#475569" Margin="0,0,0,5"/>
                    <TextBox x:Name="DescriptionTextBox" 
                             Style="{StaticResource RoundedTextBox}" 
                             Height="80" Margin="0,0,0,15" Padding="10"
                             TextWrapping="Wrap" AcceptsReturn="True" FontSize="13"
                             VerticalContentAlignment="Top"/>

                    <Label Content="Обща сума (€):" FontWeight="SemiBold" FontSize="13" Foreground="#475569" Margin="0,0,0,5"/>
                    <TextBox x:Name="AmountTextBox"
                             Style="{StaticResource RoundedTextBox}" 
                             Height="38" Margin="0,0,0,15" Padding="10,0"
                             VerticalContentAlignment="Center" FontSize="14" FontWeight="Bold"/>

                    <Label Content="Дата на извършване:" FontWeight="SemiBold" FontSize="13" Foreground="#475569" Margin="0,0,0,5"/>
                    <DatePicker x:Name="DatePicker" Height="38" Margin="0,0,0,25" VerticalContentAlignment="Center">
                        <DatePicker.Resources>

                            <!-- Закръглени краища -->

                            <Style TargetType="Border">

                                <Setter Property="CornerRadius" Value="8"/>

                                <Setter Property="Background" Value="#E3EBF5"/>

                            </Style>



                            <!-- Placeholder чрез DatePickerTextBox -->

                            <Style TargetType="DatePickerTextBox">

                                <Setter Property="Foreground" Value="#111111"/>

                                <Setter Property="Background" Value="White"/>

                                <Setter Property="HorizontalContentAlignment" Value="Left"/>

                                <Setter Property="VerticalContentAlignment" Value="Center"/>

                                <Setter Property="Text" Value="Изберете дата"/>

                            </Style>

                        </DatePicker.Resources>
                    </DatePicker>

                    <Button Style="{StaticResource MainButtonStyle}" 
                            Content="💾 Запази записа" 
                            Height="45" FontWeight="Bold"
                            HorizontalAlignment="Stretch" Click="Button_Click"
                            Cursor="Hand"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" CornerRadius="15" Background="White" Padding="20" 
                    BorderBrush="#E2E8F0" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" Opacity="0.05" ShadowDepth="2" Color="#64748B"/>
                </Border.Effect>

                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="📋" FontSize="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="История на дейностите" 
                                   FontFamily="Segoe UI" FontWeight="Bold" FontSize="18" 
                                   Foreground="#1E293B" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Separator DockPanel.Dock="Top" Margin="0,0,0,15" Background="#F1F5F9" Height="1"/>

                    <DataGrid x:Name="MaintenanceDataGrid" 
          AutoGenerateColumns="False" 
          CanUserAddRows="False" 
         CellEditEnding="MaintenanceDataGrid_CellEditEnding"
          IsReadOnly="True"
          RowHeaderWidth="0"
          GridLinesVisibility="None"
          Background="Transparent"
          BorderThickness="0"
          FontSize="13"
          RowHeight="40">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextWrapping" Value="Wrap"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Padding" Value="5"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Сума" Binding="{Binding Price, StringFormat={}{0:N2} €}" Width="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Foreground" Value="#1E293B"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Дата" Binding="{Binding DateOfMaintenance, StringFormat=dd.MM.yyyy}" Width="110">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="#64748B"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTemplateColumn Header="Действия" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Button x:Name="EditBtn" Click="EditButton_Click" 
                                ToolTip="Редактиране"
                                Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="0,0,5,0">
                                                <TextBlock Text="✏️" FontSize="14"/>
                                            </Button>

                                            <Button x:Name="DeleteButton" Click="DeleteButton_Click" 
                                ToolTip="Изтриване"
                                Background="Transparent" BorderThickness="0" Cursor="Hand">
                                                <TextBlock Text="🗑️" FontSize="14"/>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>