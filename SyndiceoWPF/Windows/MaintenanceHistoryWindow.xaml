<Window x:Class="Syndiceo.Windows.MaintenanceHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Syndiceo"
        mc:Ignorable="d"
        Title="Ремонтни дейности"
        MinWidth="600" MinHeight="400"
        Width="800" Height="468"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Icon="pack://application:,,,/Resources/Ico/logo128.ico"
        FontFamily="Calibri"
        Loaded="Window_Loaded" Background="{StaticResource AppBackground}">

    <Grid Margin="20" Background="{StaticResource AppBackground}">
        <!-- Watermark -->
        <Image Source="/Resources/logo.png"
               Opacity="0.05"
               Stretch="Uniform"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               Panel.ZIndex="0"/>

        <!-- Основно съдържание -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- Лява част – добавяне на ремонт -->
            <Border CornerRadius="10" Padding="20" BorderBrush="#DDD" BorderThickness="1" Background="Transparent" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="Добавяне на ремонтна дейност"
                               FontFamily="Calibri" FontWeight="Bold" FontSize="18"
                               HorizontalAlignment="Center" Foreground="#333"/>
                    <Separator Margin="0,10,0,10"/>

                    <!-- Описание -->
                    <StackPanel Margin="0,5,0,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,5">
                            <TextBlock Text="🔧" FontSize="16" Height="20"/>
                            <Label Content="Описание:" FontWeight="Bold" FontSize="14" Width="75"/>
                        </StackPanel>
                        <TextBox x:Name="DescriptionTextBox" 
                                 Style="{StaticResource RoundedTextBox}" 
                                 FontFamily="Calibri" Height="60" 
                                 TextWrapping="Wrap" AcceptsReturn="True"/>
                    </StackPanel>

                    <!-- Сума -->
                    <StackPanel Margin="0,10,0,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,5">
                            <TextBlock Text="💰" FontSize="16" Height="19"/>
                            <Label Content="Сума:" FontWeight="Bold" FontSize="14"/>
                        </StackPanel>
                        <TextBox x:Name="AmountTextBox"
                                 Style="{StaticResource RoundedTextBox}" 
                                 FontFamily="Calibri" Height="30"/>
                    </StackPanel>

                    <!-- Дата -->
                    <StackPanel Margin="0,10,0,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,5">
                            <TextBlock Text="📅" FontSize="16" Margin="0,0,5,0"/>
                            <Label Content="Дата:" FontWeight="Bold" FontSize="14"/>
                        </StackPanel>
                        <DatePicker x:Name="DatePicker"
                                    FontFamily="Calibri" 
                                    Height="30" FontWeight="Bold">
                            <DatePicker.Resources>
                                <!-- Закръглени краища -->
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="8"/>
                                    <Setter Property="Background" Value="#E3EBF5"/>
                                </Style>

                                <!-- Placeholder чрез DatePickerTextBox -->
                                <Style TargetType="DatePickerTextBox">
                                    <Setter Property="Foreground" Value="#111111"/>
                                    <Setter Property="Background" Value="White"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                    <Setter Property="Text" Value="Изберете дата"/>
                                </Style>
                            </DatePicker.Resources>
                        </DatePicker>
                    </StackPanel>

                    <Button Style="{StaticResource MainButtonStyle}" 
                            Content="💾 Запази ремонта" 
                            Width="180" Height="45" 
                            HorizontalAlignment="Center" Margin="0,20,0,0" Click="Button_Click"
                            />
                </StackPanel>
            </Border>

            <!-- Дясна част – списък с ремонти -->
            <Border Grid.Column="1" CornerRadius="10" Padding="20" BorderBrush="#DDD" BorderThickness="1" Background="Transparent">
                <StackPanel>
                    <TextBlock Text="История на ремонтите"
                               FontFamily="Calibri" FontWeight="Bold" FontSize="18"
                               HorizontalAlignment="Center" Foreground="#333"/>
                    <Separator Margin="0,10,0,10"/>

                    <DataGrid x:Name="MaintenanceDataGrid" 
                              AutoGenerateColumns="False" 
                              CanUserAddRows="False" 
                              IsReadOnly="True"
                              FontFamily="Calibri"
                              RowHeaderWidth="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="*"/>
                            <DataGridTextColumn Header="Сума" Binding="{Binding Price}" Width="100"/>
                            <DataGridTextColumn Header="Дата" Binding="{Binding DateOfMaintenance, StringFormat=d}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
