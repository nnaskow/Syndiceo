<Window x:Class="Syndiceo.Windows.AutoCloseMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent"
        Height="160" Width="420" Topmost="True" ShowInTaskbar="False">

    <Border Margin="10" CornerRadius="15" Background="White" BorderBrush="#E2E8F0" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Opacity="0.15" ShadowDepth="0" Color="Black"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#3498DB" CornerRadius="15,15,0,0" Opacity="0.8" Margin="4,0,3,132" Grid.RowSpan="2"/>

            <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20">
                <TextBlock x:Name="MessageText"
                           Text="Операцията приключи успешно!"
                           TextWrapping="Wrap"
                           FontSize="15"
                           FontFamily="Segoe UI Semibold"
                           Foreground="#2C3E50"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           TextAlignment="Center"/>

                <TextBlock Text="Този прозорец ще се затвори автоматично" 
                           FontSize="10" 
                           Foreground="#ABB2B9" 
                           Margin="0,10,0,0" 
                           HorizontalAlignment="Center"
                           FontStyle="Italic"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>