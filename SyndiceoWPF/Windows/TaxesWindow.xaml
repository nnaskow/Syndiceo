<Window x:Class="Syndiceo.Windows.TaxesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление на такси" Height="793" Width="900"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Background="{StaticResource AppBackground}"
        Icon="pack://application:,,,/Resources/Ico/logo128.ico"
        Loaded="Window_Loaded"
        Closing="Window_Closing">

    <!-- Основен Grid за watermark -->
    <Grid>
        <!-- Watermark -->
        <Image Source="/Resources/logo.png"
               Opacity="0.05"
               Stretch="Uniform"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               Panel.ZIndex="0"/>

        <!-- Съдържание -->
        <Grid Margin="20" Panel.ZIndex="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <Label Content="Добавяне на категория"
                       FontFamily="Calibri" FontWeight="Bold"
                       FontSize="16" HorizontalAlignment="Center"/>

                <TextBox Style="{StaticResource RoundedTextBox}" 
                         x:Name="CategoryTextBox" Height="35"
                         Margin="0,5,0,-0.3" TextAlignment="Center" KeyDown="CategoryTextBox_KeyDown"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5">
                    <Button Style="{StaticResource MainButtonStyle}" x:Name="AddCategoryButton" Content="Добави" Width="120" Height="40" Margin="0,8.7,10,0" Click="AddCategoryButton_Click"/>
                    <StackPanel Orientation="Vertical">
                        <TextBlock Text="Тип категория" Foreground="Gray" FontStyle="Italic" FontSize="12" HorizontalAlignment="Center" FontFamily="Calibri" FontWeight="Bold"/>
                        <ComboBox x:Name="CategoryKindComboBox" Height="30" Style="{StaticResource RoundComboBox}" Width="150">
                            <ComboBoxItem Content="Разход" IsSelected="True"/>
                            <ComboBoxItem Content="Приход"/>
                        </ComboBox>
                    </StackPanel>
                </StackPanel>

                <Separator Margin="0,15"/>

                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="35"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="Всички категории"
                           FontFamily="Calibri" FontWeight="Bold"
                           FontSize="16" HorizontalAlignment="Left"/>
                    <Button x:Name="addCatButton" Grid.Column="1" Content="+" Width="30" Height="30" Style ="{StaticResource SmallButtonStyle}" Click="addCatButton_Click"/>
                </Grid>

                <ListBox x:Name="CategoryListBox"
                         Height="531"
                         Background="Transparent"
                         BorderBrush="#ccc"
                         BorderThickness="1"
                         Margin="0,5"
                         DisplayMemberPath="Name"
                         SelectionMode="Extended"
                         MouseDoubleClick="CategoryListBox_MouseDoubleClick"/>
            </StackPanel>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Разходи -->
                <Border Grid.Row="0" CornerRadius="10" BorderBrush="#ccc" BorderThickness="1" Background="Transparent" Padding="10" Margin="5">
                    <StackPanel>
                        <Label Content="Разходи"
                               FontFamily="Calibri" FontWeight="Bold"
                               FontSize="16" HorizontalAlignment="Center"/>
                        <ScrollViewer Height="300">
                            <ItemsControl x:Name="ExpenseCategoriesPanel" Margin="0,10">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="0,5">
                                            <TextBlock Text="{Binding Name}" Width="150" VerticalAlignment="Center"/>
                                            <TextBox Text="{Binding Amount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                     Width="100" Height="30" VerticalContentAlignment="Center"/>
                                            <Button Content="-" Style="{StaticResource SmallButtonStyle}" Width="25" Height="25" Margin="5,0,0,0"
                                                    Click="RemoveExpenseCategory_Click"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <!-- Приходи -->
                <Border Grid.Row="1" CornerRadius="10" BorderBrush="#ccc" BorderThickness="1" Background="Transparent" Padding="10" Margin="5">
                    <StackPanel>
                        <Label Content="Приходи"
                               FontFamily="Calibri" FontWeight="Bold"
                               FontSize="16" HorizontalAlignment="Center"/>
                        <ScrollViewer Height="300">
                            <ItemsControl x:Name="IncomeCategoriesPanel" Margin="0,10">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="0,5">
                                            <TextBlock Text="{Binding Name}" Width="150" VerticalAlignment="Center"/>
                                            <TextBox Text="{Binding Amount,Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                     Width="100" Height="30" VerticalContentAlignment="Center"/>
                                            <Button Content="-" Style="{StaticResource SmallButtonStyle}" Width="25" Height="25" Margin="5,0,0,0"
                                                    Click="RemoveIncomeCategory_Click"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <!-- Наличност + Запиши -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Left" Margin="5,10" VerticalAlignment="Bottom">
                    <Label x:Name="cashboxLabel"  Content="Наличност:" VerticalAlignment="Center" Margin="0,0,10,0" FontFamily="Calibri" FontWeight="Bold"/>
                    <TextBox x:Name="Cashbox" Width="150" Height="34" Style="{StaticResource RoundedTextBox}"/>
                    <Button Style="{StaticResource MainButtonStyle}" 
                            x:Name="SaveButton"
                            Content="Запиши таксите"
                            Width="200" Height="40"
                            Margin="20,0,0,0"
                            Click="SaveButton_Click"/>
                    <Button Style="{StaticResource MainButtonStyle}" 
        x:Name="clearFieldsButton"
        Content="❌"
                            ToolTip="Задаване на нулева стойност на всички полета"
        Width="47" Height="40"
        Margin="8,0,0,0"
        Click="clearFieldsButton_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
