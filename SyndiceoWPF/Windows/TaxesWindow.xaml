<Window x:Class="Syndiceo.Windows.TaxesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление на такси" Height="850" Width="1183"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#F1F5F9"
        Icon="pack://application:,,,/Resources/Ico/logo256.ico" 
        Loaded="Window_Loaded" Closing="Window_Closing">

    <Grid>
        <Image Source="/Resources/logo.png" Opacity="0.03" Stretch="Uniform" Width="400"
               HorizontalAlignment="Center" VerticalAlignment="Center" Panel.ZIndex="0"/>

        <Grid Margin="25" Panel.ZIndex="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="25"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="20" Padding="20" BorderBrush="#E2E8F0" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" Opacity="0.05" ShadowDepth="2" Color="#64748B"/>
                </Border.Effect>

                <StackPanel>
                    <TextBlock Text="📁 Категории" FontSize="18" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,15"/>

                    <TextBlock Text="Добавяне на нова" FontSize="12" Foreground="#64748B" Margin="2,0,0,5"/>
                    <TextBox Style="{StaticResource RoundedTextBox}" 
                             x:Name="CategoryTextBox" Height="40"
                             FontSize="14" VerticalContentAlignment="Center" Padding="10,0"
                             Margin="0,0,0,10" KeyDown="CategoryTextBox_KeyDown"/>

                    <Grid Margin="0,5,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Тип" FontSize="11" Foreground="#94A3B8" Margin="2,0,0,2"/>
                            <ComboBox x:Name="CategoryKindComboBox" Height="35" Style="{StaticResource RoundComboBox}" Width="140" HorizontalAlignment="Left">
                                <ComboBoxItem Content="Разход" IsSelected="True"/>
                                <ComboBoxItem Content="Приход"/>
                            </ComboBox>
                        </StackPanel>

                        <Button Grid.Column="1" Style="{StaticResource MainButtonStyle}" 
                                x:Name="AddCategoryButton" Content="Добави" FontSize="14"
                                Width="120" Height="40" VerticalAlignment="Bottom"
                                Click="AddCategoryButton_Click"/>
                    </Grid>

                    <Separator Background="#F1F5F9" Margin="0,10"/>

                    <Grid Margin="0,10">
                        <TextBlock Text="Налични категории" FontSize="14" FontWeight="SemiBold" Foreground="#475569" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="addCatButton" HorizontalAlignment="Right" Content="+" 
                                Width="32" Height="32" Style="{StaticResource CleanIconButton}" Foreground="Green"
                                FontSize="18" Click="addCatButton_Click"/>
                            <Button x:Name="removeCatButton" HorizontalAlignment="Right" Content="-" 
                                 Width="32" Height="32" Style="{StaticResource CleanIconButton}" Foreground="Red"
                                 FontSize="18" Click="removeCatButton_Click"/>
                        </StackPanel>
                    </Grid>

                    <ListBox x:Name="CategoryListBox"
                             Height="480"
                             Background="#F8FAFC"
                             BorderBrush="#E2E8F0"
                             BorderThickness="1"
                             DisplayMemberPath="Name"
                             SelectionMode="Extended"
                             FontSize="14"
                             Padding="5"
                             MouseDoubleClick="CategoryListBox_MouseDoubleClick">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="10,8"/>
                                <Setter Property="Margin" Value="2"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#2563EB"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </StackPanel>
            </Border>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border x:Name="ApartmentNavigation" Grid.Row="0" Background="White" CornerRadius="20" Padding="15,10" Margin="0,0,0,15" BorderBrush="#E2E8F0" BorderThickness="1">
                    <Grid>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                            <TextBlock Text="🏠 Апартамент:" FontSize="16" FontWeight="Bold" Foreground="#64748B" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock x:Name="CurrentApartmentTextBlock" Text="№ 00" FontSize="20" FontWeight="ExtraBold" Foreground="#2563EB" VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel x:Name="NavigationPanel" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="PrevApartmentButton" Content="❮" 
            Style="{StaticResource CleanIconButton}" 
            Foreground="#2563EB" Width="40" Height="40" 
            FontSize="22" Click="PrevApartmentButton_Click"
            Cursor="Hand"/>

                            <TextBox x:Name="ApartmentSearchTextBox" Width="70" Height="35" Margin="8,0"
             VerticalContentAlignment="Center" TextAlignment="Center" FontSize="16"
             Style="{StaticResource RoundedTextBox}" FontWeight="Bold" 
             KeyDown="ApartmentSearchTextBox_KeyDown"/>

                            <Button x:Name="NextApartmentButton" Content="❯" 
            Style="{StaticResource CleanIconButton}" 
            Foreground="#2563EB" Width="40" Height="40" 
            FontSize="22" Click="NextApartmentButton_Click"
            Cursor="Hand"/>
                        </StackPanel>
                    </Grid>
                </Border>
                <Border Grid.Row="1" CornerRadius="20" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" Padding="20" Margin="0,0,0,10">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="💸 Разходи" FontSize="17" FontWeight="Bold" Foreground="#DC2626" Margin="0,0,0,15"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="ExpenseCategoriesPanel">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#FFF1F2" Margin="0,0,0,8" Padding="10" CornerRadius="10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="120"/>
                                                    <ColumnDefinition Width="40"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="14" Foreground="#991B1B"/>
                                                <TextBox Grid.Column="1" Text="{Binding Amount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                         Style="{StaticResource RoundedTextBox}" Height="32" TextAlignment="Right" Padding="8,0"/>
                                                <Button Grid.Column="2" Content="✕" Style="{StaticResource SmallButtonStyle}" 
                                                        Width="28" Height="28" Margin="8,0,0,0" Foreground="Red"
                                                        Click="RemoveExpenseCategory_Click"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <Border Grid.Row="2" CornerRadius="20" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" Padding="20" Margin="0,10,0,10">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="💰 Приходи" FontSize="17" FontWeight="Bold" Foreground="#16A34A" Margin="0,0,0,15"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="IncomeCategoriesPanel">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#F0FDF4" Margin="0,0,0,8" Padding="10" CornerRadius="10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="120"/>
                                                    <ColumnDefinition Width="40"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="14" Foreground="#166534"/>
                                                <TextBox Grid.Column="1" Text="{Binding Amount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                         Style="{StaticResource RoundedTextBox}" Height="32" TextAlignment="Right" Padding="8,0"/>
                                                <Button Grid.Column="2" Content="✕" Style="{StaticResource SmallButtonStyle}" 
                                                        Width="28" Height="28" Margin="8,0,0,0" Foreground="Red"
                                                        Click="RemoveIncomeCategory_Click"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <Border Grid.Row="3" Background="#1E293B" CornerRadius="20" Padding="20" Margin="0,15,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock x:Name="cashboxLabel" 
                       Text="КАСОВА НАЛИЧНОСТ:" 
                       Foreground="#94A3B8" 
                       FontWeight="Bold" 
                       FontSize="13"
                       VerticalAlignment="Center" 
                       Margin="0,0,12,0"/>

                            <TextBox x:Name="Cashbox" 
                     Width="120" 
                     Height="40" 
                     Background="#334155" 
                     Foreground="White" 
                     BorderThickness="0" 
                     FontSize="16" 
                     FontWeight="Bold" 
                     TextAlignment="Center" 
                     Style="{StaticResource RoundedTextBox}" 
                     VerticalContentAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button x:Name="clearFieldsButton" 
                    Content="ИЗЧИСТВАНЕ" 
                    Style="{StaticResource ClearButtonStyle}" 
                    Width="115" 
                    Height="40" 
                    Margin="0,0,12,0" 
                    Click="clearFieldsButton_Click"/>

                            <Button x:Name="SaveOnlyButton" 
                    Content="АКТУАЛИЗИРАЙ" 
                    Style="{StaticResource SaveButtonStyle}" 
                    Width="143" 
                    Height="40" 
                    Margin="0,0,10,0" 
                    Background="#0F172A" 
                    Click="SaveOnlyButton_Click"/>

                            <Button x:Name="SaveAndCloseButton" 
                    Content="ПОТВЪРДИ И ЗАТВОРИ" 
                    Style="{StaticResource SaveButtonStyle}" 
                    Width="180" 
                    Height="40" 
                    FontWeight="Bold" 
                    Click="SaveAndCloseButton_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>