<Window x:Class="Syndiceo.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Syndiceo" Height="660" Width="420"
        Icon="pack://application:,,,/Resources/Ico/logo256.ico"
        ResizeMode="CanMinimize" WindowStartupLocation="CenterScreen"   
        UseLayoutRounding="True" SnapsToDevicePixels="True"
        Loaded="Window_Loaded" >

    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F8FAFC" Offset="0.0"/>
            <GradientStop Color="#E2E8F0" Offset="1.0"/>
        </LinearGradientBrush>
    </Window.Background>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="13*"/>
        </Grid.RowDefinitions>
        <Ellipse Width="300" Height="300" Fill="{StaticResource PrimaryColor}" Opacity="0.08" 
                 HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-100,-100,0,0" Grid.RowSpan="2"/>
        <Ellipse Width="220" Height="220" Fill="{StaticResource PrimaryColor}" Opacity="0.06" 
                 HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-60,-60" Grid.Row="1"/>

        <Border Margin="35,35,35,35" CornerRadius="16" Background="White" 
                BorderBrush="#CBD5E1" BorderThickness="1" Grid.RowSpan="2">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" ShadowDepth="4" Opacity="0.1" Color="#64748B"/>
            </Border.Effect>

            <Grid Margin="25,15">

                <Grid Name="LoginGrid" Visibility="Visible">
                    <StackPanel VerticalAlignment="Center">
                        <Image Source="/Resources/logo.png" Height="100" Margin="0,0,0,10"/>
                        <TextBlock Text="Syndiceo" FontSize="28" FontWeight="ExtraBold" Foreground="{StaticResource PrimaryColor}" HorizontalAlignment="Center" />

                        <Grid Margin="0,5,0,25">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <Separator VerticalAlignment="Center" Margin="10,0" Opacity="0.2"/>
                            <TextBlock Grid.Column="1" Text="ИДЕНТИФИКАЦИЯ" FontSize="9" FontWeight="Bold" Foreground="DarkGray"/>
                            <Separator Grid.Column="2" VerticalAlignment="Center" Margin="10,0" Opacity="0.2"/>
                        </Grid>

                        <TextBlock Text="ПОТРЕБИТЕЛ" FontSize="10" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}" Margin="5,0,0,5" Opacity="0.6"/>
                        <TextBox Name="usernameTxtBox" Style="{StaticResource RoundedTextBox}" Height="42" Margin="0,0,0,15" VerticalContentAlignment="Center" KeyDown="usernameTxtBox_KeyDown"/>

                        <TextBlock Text="ПАРОЛА" FontSize="10" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}" Margin="5,0,0,5" Opacity="0.6"/>
                        <Grid Margin="0,0,0,5">
                            <PasswordBox x:Name="passwordBox" Style="{StaticResource RoundedPasswordBox}" Height="42" VerticalContentAlignment="Center" KeyDown="passwordBox_KeyDown"/>
                            <TextBox x:Name="passwordTextVisible" Visibility="Collapsed" Style="{StaticResource RoundedTextBox}" Height="42" VerticalContentAlignment="Center" TextChanged="passwordTextVisible_TextChanged" KeyDown="passwordTextVisible_KeyDown"/>
                        </Grid>

                        <CheckBox Name="ShowPassword" Style="{StaticResource ModernCheckBox}" Content="Покажи парола" HorizontalAlignment="Right" FontSize="10" Foreground="DimGray" Margin="0,0,0,20" Checked="ShowPassword_Checked" Unchecked="ShowPassword_Unchecked" FontWeight="Bold"/>

                        <Button Name="LoginButton" Content="ВХОД" Style="{StaticResource MainButtonStyle}" Height="48" Width="200" HorizontalAlignment="Center" Click="LoginButton_Click" Margin="0,0,0,10"/>

                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                            <CheckBox  Style="{StaticResource ModernCheckBox}" Name="remembermeCheckbox" Content="Запомни ме" FontSize="11" FontWeight="Bold" Foreground="DimGray" HorizontalAlignment="Center" Margin="0,5" Checked="remembermeCheckbox_Checked" Unchecked="remembermeCheckbox_Unchecked"/>
                            <Button Content="Забравена парола?" x:Name="ForgottenPasswordButton" Click="ForgottenPasswordButton_Click" Background="Transparent" BorderThickness="0" Foreground="{StaticResource PrimaryColor}" FontSize="11" FontWeight="Bold" Cursor="Hand" Margin="0,5"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <Grid Name="RegisterGrid" Visibility="Collapsed">
                    <StackPanel VerticalAlignment="Center">
                        <Image Source="/Resources/logo.png" Height="90" Margin="0,0,0,10"/>
                        <TextBlock Text="Syndiceo" FontSize="26" FontWeight="ExtraBold" Foreground="{StaticResource PrimaryColor}" HorizontalAlignment="Center" Margin="0,0,0,15" />

                        <TextBlock Text="РЕГИСТРАЦИЯ" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}" HorizontalAlignment="Center"/>
                        <Separator Width="120" Margin="0,15" Opacity="0.2"/>

                        <TextBlock Text="ВАШЕТО ИМЕ" FontSize="10" FontWeight="Bold" Margin="5,0,0,5" Opacity="0.6"/>
                        <TextBox x:Name="nameTxtBox" Style="{StaticResource RoundedTextBox}" Height="38" Margin="0,0,0,10" KeyDown="nameTxtBox_KeyDown"/>

                        <TextBlock Text="ПОТРЕБИТЕЛСКО ИМЕ" FontSize="10" FontWeight="Bold" Margin="5,0,0,5" Opacity="0.6"/>
                        <TextBox x:Name="usernameTxtBoxReg" Style="{StaticResource RoundedTextBox}" Height="38" Margin="0,0,0,10" KeyDown="usernameTxtBoxReg_KeyDown"/>

                        <TextBlock Text="ПАРОЛА" FontSize="10" FontWeight="Bold" Margin="5,0,0,5" Opacity="0.6"/>
                        <Grid Margin="0,0,0,5">
                            <PasswordBox x:Name="passwordTextBoxReg" Style="{StaticResource RoundedPasswordBox}" Height="38" KeyDown="passwordTextBoxReg_KeyDown"/>
                            <TextBox x:Name="passwordTextVisibleReg" Visibility="Collapsed" Style="{StaticResource RoundedTextBox}" Height="38" TextChanged="passwordTextVisibleReg_TextChanged"/>
                        </Grid>

                        <CheckBox Name="ShowPasswordReg" Style="{StaticResource ModernCheckBox}" Content="Покажи парола" HorizontalAlignment="Right" FontSize="10" Margin="0,0,0,15" Checked="ShowPasswordReg_Checked" Unchecked="ShowPasswordReg_Unchecked" FontWeight="Bold"/>

                        <Button x:Name="RegisterButton" Content="СЪЗДАЙ ПРОФИЛ" Style="{StaticResource MainButtonStyle}" Height="45" Click="RegisterButton_Click"/>
                        <Button Content="Отказ" Background="Transparent" BorderThickness="0" Margin="0,10,0,0" FontWeight="Bold" Click="BackToLoginBtn_Click"/>
                    </StackPanel>
                </Grid>

                <Grid x:Name="ForgotPasswordGrid" Visibility="Collapsed">
                    <StackPanel VerticalAlignment="Center">
                        <Image Source="/Resources/logo.png" Height="90" Margin="0,0,0,10"/>
                        <TextBlock Text="СИГУРНОСТ" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                        <Border Background="#F8FAFC" CornerRadius="12" Padding="15,10" Margin="0,0,0,15" BorderBrush="#E2E8F0" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="ВАШИЯТ ВЪПРОС:" FontSize="9" FontWeight="Black" Foreground="#94A3B8" Margin="0,0,0,5"/>
                                <TextBlock x:Name="SecurityQuestionTxt" Text="Въпрос..." FontSize="13" Foreground="#1E293B" FontWeight="SemiBold" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="ВАШИЯТ ОТГОВОР" FontSize="10" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}" Margin="5,0,0,5"/>
                        <TextBox x:Name="SecurityAnswerTxtBox" Height="40" Margin="0,0,0,20" Style="{StaticResource RoundedTextBox}" />

                        <Button Content="ВЪЗСТАНОВИ" Style="{StaticResource MainButtonStyle}" Height="48" FontWeight="Bold" x:Name="RestorePasswordButton" Click="RestorePasswordButton_Click"/>
                        <Button x:Name="BackToLoginBtn" Content="Назад" Background="Transparent" Foreground="#94A3B8" BorderThickness="0" Margin="0,15,0,0" Click="BackToLoginBtn_Click"/>
                    </StackPanel>
                </Grid>

                <Grid Name="SecuritySetupGrid" Visibility="Collapsed">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="НАСТРОЙКА" FontSize="20" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                        <TextBlock Text="ИЗБЕРЕТЕ ВЪПРОС" FontSize="10" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}" Margin="5,0,0,5" Opacity="0.6"/>
                        <ComboBox x:Name="SetupQuestionCombo" Style="{StaticResource RoundComboBox}" Height="40" Margin="0,0,0,15">
                            <ComboBoxItem Content="Име на първия ви домашен любимец?" IsSelected="True"/>
                            <ComboBoxItem Content="В кой град сте родени?"/>
                        </ComboBox>

                        <TextBlock Text="ОТГОВОР" FontSize="10" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}" Margin="5,0,0,5" Opacity="0.6"/>
                        <TextBox x:Name="SetupAnswerTxtBox" Style="{StaticResource RoundedTextBox}" Height="40" Margin="0,0,0,25"/>

                        <Button x:Name="SaveSecurityButton" Content="ЗАПАЗИ" Style="{StaticResource MainButtonStyle}" Height="45" Click="SaveSecurityButton_Click"/>
                    </StackPanel>
                </Grid>

                <Grid x:Name="ResetPasswordGrid" Visibility="Collapsed">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="НОВА ПАРОЛА" FontSize="22" FontWeight="Black" Foreground="{StaticResource PrimaryColor}" HorizontalAlignment="Center" Margin="0,0,0,20" />

                        <PasswordBox x:Name="NewPasswordBox" Style="{StaticResource RoundedPasswordBox}" Height="45" Margin="0,0,0,15"/>
                        <PasswordBox x:Name="ConfirmPasswordBox" Style="{StaticResource RoundedPasswordBox}" Height="45" Margin="0,0,0,25"/>

                        <Button x:Name="SaveNewPasswordBtn" Content="ОБНОВИ И ВЛЕЗ" Style="{StaticResource MainButtonStyle}" Height="50" Click="SaveNewPasswordBtn_Click"/>
                    </StackPanel>
                </Grid>

            </Grid>
        </Border>
    </Grid>
</Window>