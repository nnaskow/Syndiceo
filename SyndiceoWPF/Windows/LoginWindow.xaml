<Window x:Class="Syndiceo.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Syndiceo" Height="660" Width="420"
        Background="{StaticResource AppBackground}"
        Icon="pack://application:,,,/Resources/Ico/logo256.ico"
        ResizeMode="CanMinimize" WindowStartupLocation="CenterScreen"   
        UseLayoutRounding="True" SnapsToDevicePixels="True"
        Loaded="Window_Loaded">

    <Grid>
        <Border Margin="30" CornerRadius="20" Background="White">
            <Border.Effect>
                <DropShadowEffect BlurRadius="25" ShadowDepth="2" Opacity="0.1"/>
            </Border.Effect>

            <Grid Margin="25,15">

                <Grid Name="LoginGrid" Visibility="Collapsed">
                    <StackPanel VerticalAlignment="Center">
                        <Image Source="/Resources/logo.png" Height="110" Margin="0,0,0,10"/>
                        <TextBlock Text="Syndiceo" FontSize="28" FontWeight="ExtraBold" Foreground="{StaticResource PrimaryColor}" HorizontalAlignment="Center" />

                        <Grid Margin="0,5,0,30">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <Separator VerticalAlignment="Center" Margin="10,0" Opacity="0.2"/>
                            <TextBlock Grid.Column="1" Text="ИДЕНТИФИКАЦИЯ" FontSize="9" FontWeight="Bold" Foreground="DarkGray"/>
                            <Separator Grid.Column="2" VerticalAlignment="Center" Margin="10,0" Opacity="0.2"/>
                        </Grid>

                        <TextBlock Text="ПОТРЕБИТЕЛ" FontSize="10" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}" Margin="5,0,0,5" Opacity="0.6"/>
                        <TextBox Name="usernameTxtBox" Style="{StaticResource RoundedTextBox}" Height="40" Margin="0,0,0,15" KeyDown="usernameTxtBox_KeyDown"/>

                        <TextBlock Text="ПАРОЛА" FontSize="10" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}" Margin="5,0,0,5" Opacity="0.6"/>
                        <Grid Margin="0,0,0,5">
                            <PasswordBox x:Name="passwordBox" Style="{StaticResource RoundedPasswordBox}" Height="40" KeyDown="passwordBox_KeyDown"/>
                            <TextBox x:Name="passwordTextVisible" Visibility="Collapsed" Style="{StaticResource RoundedTextBox}" Height="40" TextChanged="passwordTextVisible_TextChanged" KeyDown="passwordTextVisible_KeyDown"/>
                        </Grid>

                        <CheckBox Name="ShowPassword" Content="Покажи парола" HorizontalAlignment="Right" FontSize="10" Foreground="DimGray" Margin="0,0,0,20" Checked="ShowPassword_Checked" Unchecked="ShowPassword_Unchecked" FontWeight="Bold"/>

                        <Button Name="LoginButton" Content="ВХОД" Style="{StaticResource MainButtonStyle}" Height="45" Click="LoginButton_Click" Margin="0,0,0,10"/>

                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                            <CheckBox Name="remembermeCheckbox" Content="Запомни ме" FontSize="11" FontWeight="Bold" Foreground="DimGray" HorizontalAlignment="Center" Margin="0,5" Checked="remembermeCheckbox_Checked" Unchecked="remembermeCheckbox_Unchecked"/>
                            <Button Content="Забравена парола?" x:Name="ForgottenPasswordButton" Click="ForgottenPasswordButton_Click" Background="Transparent" BorderThickness="0" Foreground="{StaticResource PrimaryColor}" FontSize="11" FontWeight="Bold" Cursor="Hand" Margin="0,5"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <Grid Name="RegisterGrid" Visibility="Visible">
                    <StackPanel VerticalAlignment="Center">
                        <Image Source="/Resources/logo.png" Height="110" Margin="0,0,0,10"/>
                        <TextBlock Text="Syndiceo" FontSize="28" FontWeight="ExtraBold" Foreground="{StaticResource PrimaryColor}" HorizontalAlignment="Center" Margin="0,0,0,20" />

                        <TextBlock Text="РЕГИСТРАЦИЯ" FontSize="20" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}" HorizontalAlignment="Center"/>
                        <Separator Width="150" Margin="0,15" Opacity="0.2"/>

                        <TextBlock Text="ВАШЕТО ИМЕ" FontSize="10" FontWeight="Bold" Margin="5,0,0,5" Opacity="0.6"/>
                        <TextBox x:Name="nameTxtBox" Style="{StaticResource RoundedTextBox}" Height="38" Margin="0,0,0,10" KeyDown="nameTxtBox_KeyDown"/>

                        <TextBlock Text="ПОТРЕБИТЕЛСКО ИМЕ" FontSize="10" FontWeight="Bold" Margin="5,0,0,5" Opacity="0.6"/>
                        <TextBox x:Name="usernameTxtBoxReg" Style="{StaticResource RoundedTextBox}" Height="38" Margin="0,0,0,10" KeyDown="usernameTxtBoxReg_KeyDown"/>
  
                        <TextBlock Text="ИМЕЙЛ" FontSize="10" FontWeight="Bold" Margin="5,0,0,5" Opacity="0.6"/>
                        <TextBox x:Name="emailTxtBox" Style="{StaticResource RoundedTextBox}" Height="38" Margin="0,0,0,10" KeyDown="emailTxtBox_KeyDown"/>

                        <TextBlock Text="ПАРОЛА" FontSize="10" FontWeight="Bold" Margin="5,0,0,5" Opacity="0.6"/>
                        <Grid Margin="0,0,0,5">
                            <PasswordBox x:Name="passwordTextBoxReg" Style="{StaticResource RoundedPasswordBox}" Height="38" KeyDown="passwordTextBoxReg_KeyDown"/>
                            <TextBox x:Name="passwordTextVisibleReg" Visibility="Collapsed" Style="{StaticResource RoundedTextBox}" Height="38" TextChanged="passwordTextVisibleReg_TextChanged"/>
                        </Grid>

                        <CheckBox Name="ShowPasswordReg" Content="Покажи парола" HorizontalAlignment="Right" FontSize="10" Margin="0,0,0,15" Checked="ShowPasswordReg_Checked" Unchecked="ShowPasswordReg_Unchecked" FontWeight="Bold"/>

                        <Button x:Name="RegisterButton" Content="СЪЗДАЙ ПРОФИЛ" Style="{StaticResource MainButtonStyle}" Height="45" Click="RegisterButton_Click"/>
                        <Button Content="Отказ" Background="Transparent" BorderThickness="0" Margin="0,10,0,0" FontWeight="Bold"/>
                    </StackPanel>
                </Grid>

                <Grid x:Name="ForgotPasswordGrid" Visibility="Collapsed">
                    <StackPanel VerticalAlignment="Center">
                        <Image Source="/Resources/logo.png" Height="100" Margin="0,0,0,10"/>
                        <TextBlock Text="Syndiceo" FontSize="28" FontWeight="Black" Foreground="{StaticResource PrimaryColor}" HorizontalAlignment="Center" Margin="0,0,0,5" />
                        <TextBlock Text="СИГУРНОСТ" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}" HorizontalAlignment="Center" Opacity="0.8"/>

                        <TextBlock Text="Отговорете на зададеният от вас въпрос, за да възстановите паролата си" 
                   Foreground="Gray" FontSize="11" TextWrapping="Wrap" TextAlignment="Center" Margin="0,15,0,20"/>

                        <Border Background="#F8FAFC" CornerRadius="12" Padding="15,10" Margin="0,0,0,15" BorderBrush="#E2E8F0" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="ВАШИЯТ ВЪПРОС:" FontSize="9" FontWeight="Black" Foreground="#94A3B8" Margin="0,0,0,5"/>
                                <TextBlock x:Name="SecurityQuestionTxt" Text="Какво беше името на първия ви домашен любимец?" 
                           FontSize="13" Foreground="#1E293B" FontWeight="SemiBold" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="ВАШИЯТ ОТГОВОР" FontSize="10" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}" Margin="5,0,0,5"/>
                        <TextBox x:Name="SecurityAnswerTxtBox" Height="40" Margin="0,0,0,20" 
                     Style="{StaticResource RoundedTextBox}" />
                        <Button Content="ВЪЗСТАНОВИ ПАРОЛА" Style="{StaticResource MainButtonStyle}" Height="48" FontWeight="Bold" x:Name="RestorePasswordButton" Click="RestorePasswordButton_Click"/>

                        <Button x:Name="BackToLoginBtn" Content="Назад към вход" Background="Transparent" 
                Foreground="#94A3B8" BorderThickness="0" Margin="0,15,0,0" FontWeight="SemiBold" Cursor="Hand" Click="BackToLoginBtn_Click"/>
                    </StackPanel>
                </Grid>

                <Grid Name="SecurityQuestionGrid" Visibility="Collapsed">
                </Grid>

                <Grid Name="SecuritySetupGrid" Visibility="Collapsed">
                    <StackPanel VerticalAlignment="Center">
                        <Image Source="/Resources/logo.png" Height="90" Margin="0,0,0,10"/>
                        <TextBlock Text="НАСТРОЙКА НА СИГУРНОСТ" FontSize="20" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                        <TextBlock Text="Изберете въпрос за възстановяване на паролата" FontSize="11" Foreground="Gray" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,20"/>

                        <TextBlock Text="ИЗБЕРЕТЕ ВЪПРОС" FontSize="10" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}" Margin="5,0,0,5" Opacity="0.6"/>
                        <ComboBox x:Name="SetupQuestionCombo" Style="{StaticResource RoundComboBox}" Height="40" Margin="0,0,0,15" VerticalContentAlignment="Center" Background="White">
                            <ComboBoxItem Content="Име на първия ви домашен любимец?" IsSelected="True"/>
                            <ComboBoxItem Content="В кой град сте родени?"/>
                            <ComboBoxItem Content="Марка на първата ви кола?"/>
                            <ComboBoxItem Content="Име на любимата ви детска учителка?"/>
                            <ComboBoxItem Content="Любимо ястие от детството?"/>
                        </ComboBox>

                        <TextBlock Text="ВАШИЯТ ОТГОВОР" FontSize="10" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}" Margin="5,0,0,5" Opacity="0.6"/>
                        <TextBox x:Name="SetupAnswerTxtBox" Style="{StaticResource RoundedTextBox}" Height="40" Margin="0,0,0,25"/>

                        <Button x:Name="SaveSecurityButton" Content="ЗАПАЗИ И ПРОДЪЛЖИ" Style="{StaticResource MainButtonStyle}" Height="45" Click="SaveSecurityButton_Click"/>

                        <TextBlock Text="* Този въпрос ще ви е нужен, ако забравите паролата си." FontSize="9" Foreground="LightGray" HorizontalAlignment="Center" Margin="0,15,0,0"/>
                    </StackPanel>
                </Grid>

                <Grid x:Name="ResetPasswordGrid" Visibility="Collapsed">
                    <StackPanel VerticalAlignment="Center">
                        <Border Width="60" Height="60" Background="#F0FDF4" CornerRadius="30" Margin="0,0,0,20">
                            <Image Source="/Resources/logo.png" Margin="0,-22,0,-30"/>
                        </Border>

                        <TextBlock Text="НОВА ПАРОЛА" FontSize="24" FontWeight="Black" 
                   Foreground="{StaticResource PrimaryColor}" HorizontalAlignment="Center" Margin="0,0,0,5" />

                        <TextBlock Text="Само още една стъпка до достъпа ви" 
                   Foreground="Gray" FontSize="11" HorizontalAlignment="Center" Margin="0,0,0,25"/>

                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Text="НОВА ПАРОЛА" FontSize="10" FontWeight="Bold" 
                       Foreground="{StaticResource PrimaryColor}" Margin="5,0,0,5"/>
                            <PasswordBox x:Name="NewPasswordBox" Style="{StaticResource RoundedPasswordBox}" Height="45"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,25">
                            <TextBlock Text="ПОТВЪРДЕТЕ ПАРОЛАТА" FontSize="10" FontWeight="Bold" 
                       Foreground="{StaticResource PrimaryColor}" Margin="5,0,0,5"/>
                            <PasswordBox x:Name="ConfirmPasswordBox" Style="{StaticResource RoundedPasswordBox}" Height="45"/>
                        </StackPanel>

                        <Button x:Name="SaveNewPasswordBtn" 
                Content="ЗАПАЗИ И ВЛЕЗ" 
                Style="{StaticResource MainButtonStyle}" 
                Height="50" 
                FontWeight="Bold"
                Click="SaveNewPasswordBtn_Click"/>

                        <Button Content="Отказ" Background="Transparent" Foreground="#94A3B8" 
                BorderThickness="0" Margin="0,15,0,0" FontWeight="SemiBold"
                Click="BackToLoginBtn_Click"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>