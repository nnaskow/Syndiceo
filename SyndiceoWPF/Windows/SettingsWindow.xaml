<Window x:Class="Syndiceo.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройки"
        MinWidth="920" MinHeight="550"
        Width="1000" Height="650"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Icon="pack://application:,,,/Resources/Ico/logo256.ico"
        Background="#F1F5F9"
        Loaded="Window_Loaded">

    <Grid Margin="0">
        <DockPanel Margin="25">
            <StackPanel DockPanel.Dock="Top" Margin="5,0,0,20">
                <TextBlock Text="Настройки на приложението" FontFamily="Segoe UI" HorizontalAlignment="Center" FontWeight="Bold" FontSize="26" Foreground="#1E293B"/>
                <Separator Background="#E2E8F0" Margin="0,10,0,0" Height="1"/>
            </StackPanel>

            <Button DockPanel.Dock="Bottom" Style="{StaticResource MainButtonStyle}" 
                    Content="💾 Запази всички настройки" 
                    Width="280" Height="50" FontSize="16" FontWeight="Bold"
                    Foreground="White"
                    Click="Button_Click_1" Margin="0,20,0,0" HorizontalAlignment="Right" Cursor="Hand"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" CornerRadius="15" Background="White" Padding="25" Margin="0,0,15,0" 
                        BorderBrush="#E2E8F0" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="15" Opacity="0.05" ShadowDepth="2" Color="#64748B"/>
                    </Border.Effect>

                    <StackPanel>
                        <TextBlock Text="👤 Потребителски данни" FontSize="18" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,20"/>

                        <Ellipse Width="80" Height="80" HorizontalAlignment="Center" Margin="0,0,0,25">
                            <Ellipse.Fill>
                                <ImageBrush ImageSource="/Resources/profile-icon-design-free-vector.jpg" Stretch="UniformToFill"/>
                            </Ellipse.Fill>
                        </Ellipse>

                        <Grid Margin="0,10">
                            <TextBlock Text="Име:" VerticalAlignment="Center" Foreground="#64748B" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock x:Name="nameLabel" Text="Петър Петров" Margin="110,0,100,0" VerticalAlignment="Center" FontWeight="Bold" Foreground="#1E293B" TextDecorations="Underline"/>
                            <Button x:Name="labelButton" Content="Промяна" HorizontalAlignment="Right" Click="labelButton_Click" 
                                    Style="{StaticResource CleanIconButton}" FontSize="14" Height="32" Width="90" FontWeight="Bold" Foreground="#1E293B"/>
                        </Grid>
                        <Separator Background="#F1F5F9"/>

                        <Grid Margin="0,10">
                            <TextBlock Text="Username:" VerticalAlignment="Center" Foreground="#64748B" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock x:Name="usernameLabel" Text="p.petrov" Margin="110,0,100,0" VerticalAlignment="Center" FontWeight="Bold" Foreground="#1E293B" TextDecorations="Underline"/>
                            <Button x:Name="usernameButton" Content="Промяна" HorizontalAlignment="Right" Click="usernameButton_Click" 
                                   Style="{StaticResource CleanIconButton}" FontSize="14" Height="32" Width="90" FontWeight="Bold" Foreground="#1E293B"/>
                        </Grid>
                        <Separator Background="#F1F5F9"/>

                        <Grid Margin="0,10">
                            <TextBlock Text="Имейл:" VerticalAlignment="Center" Foreground="#64748B" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock x:Name="emailLabel" Text="petar@example.com" Margin="110,0,100,0" VerticalAlignment="Center" FontWeight="Bold" Foreground="#1E293B" TextDecorations="Underline"/>
                            <Button x:Name="emailButton" Content="Промяна" HorizontalAlignment="Right" Click="emailButton_Click" 
                                   Style="{StaticResource CleanIconButton}" FontSize="14" Height="32" Width="90" FontWeight="Bold" Foreground="#1E293B"/>
                        </Grid>
                        <Separator Background="#F1F5F9"/>

                        <Grid Margin="0,10">
                            <TextBlock Text="Парола:" VerticalAlignment="Center" Foreground="#64748B" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock x:Name="passwordLabel" Text="********" Margin="110,0,100,0" VerticalAlignment="Center" FontWeight="Bold" Foreground="#1E293B" TextDecorations="Underline"/>
                            <Button x:Name="passwordButton" Content="Промяна" HorizontalAlignment="Right" Click="passwordButton_Click" 
                                    Style="{StaticResource CleanIconButton}" FontSize="14" Height="32" Width="90" FontWeight="Bold" Foreground="#1E293B"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <Border CornerRadius="15" Background="White" Padding="20" Margin="0,0,0,15" BorderBrush="#E2E8F0" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="💾 База данни" FontSize="17" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,15"/>
                            <CheckBox x:Name="AutoSaveCheckBox" Content="Автоматично запазване" FontSize="14" Margin="0,0,0,15" FontWeight="Medium" Foreground="#1E293B"
                                      Checked="AutoSaveCheckBox_Checked" Unchecked="AutoSaveCheckBox_Unchecked"/>

                            <TextBlock Text="Път до базата данни:" FontSize="12" Foreground="#64748B" Margin="0,0,0,5"/>
                            <TextBox x:Name="DatabasePathTextBox" Style="{StaticResource RoundedTextBox}" Height="36" IsReadOnly="True" Background="#F8FAFC" FontSize="11" Padding="10,0" VerticalContentAlignment="Center" Margin="0,0,0,15"/>

                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Архив:" VerticalAlignment="Center" FontSize="14" Foreground="#1E293B"/>
                                <Button x:Name="LoadArchiveButton" Style="{StaticResource CleanIconButton}" FontSize="14" Content="Избери файл..." 
                                        Width="110" Height="30" Margin="15,0,0,0" Click="LoadArchiveButton_Click" FontWeight="Bold" Foreground="#1E293B"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border CornerRadius="15" Background="White" Padding="20" BorderBrush="#E2E8F0" BorderThickness="1" x:Name="otherSettings">
                        <StackPanel>
                            <TextBlock Text="⚙️ Предпочитания" FontSize="17" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,15"/>
                            <CheckBox x:Name="RememberUsernameCheckBox" Content="Запомни потребителско име" FontSize="14" Margin="0,0,0,10" Foreground="#1E293B"
                                      Checked="RememberUsernameCheckBox_Checked" Unchecked="RememberUsernameCheckBox_Unchecked"/>
                            <CheckBox x:Name="RememberPasswordCheckBox" Content="Запомни парола" FontSize="14" Foreground="#1E293B"
                                      Checked="RememberPasswordCheckBox_Checked" Unchecked="RememberPasswordCheckBox_Unchecked"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </DockPanel>
    </Grid>
</Window>