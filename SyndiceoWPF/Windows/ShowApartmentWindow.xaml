<Window x:Class="Syndiceo.Windows.ShowApartmentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Данни за апартамента"
        MinWidth="900" MinHeight="500"
        Width="1000" Height="650"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Icon="pack://application:,,,/Resources/Ico/logo256.ico"
        Loaded="Window_Loaded" 
        Background="#F1F5F9">

    <Grid>
        <DockPanel Margin="25">

            <Border DockPanel.Dock="Top" CornerRadius="15" Background="#1E293B" Padding="18" Margin="0,0,0,20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" Opacity="0.1" ShadowDepth="2"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="📍 ЛОКАЦИЯ НА ОБЕКТА" 
                               FontSize="11" FontWeight="Bold" 
                               Foreground="#94A3B8" Margin="0,0,0,6" 
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="FullAddressLabel"
                               Text="Зареждане на адрес..."
                               FontFamily="Segoe UI" FontWeight="Bold" FontSize="20" 
                               TextWrapping="Wrap" TextAlignment="Center"
                               Foreground="White"/>
                </StackPanel>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="400"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" CornerRadius="15" Background="White" Padding="25" Margin="0,0,15,0" BorderBrush="#E2E8F0" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" Opacity="0.05" ShadowDepth="4" Color="#64748B"/>
                    </Border.Effect>

                    <StackPanel VerticalAlignment="Top">
                        <TextBlock Text="👤 Собственик и живущи" 
                                   FontWeight="Bold" FontSize="18" 
                                   Foreground="#1E293B" Margin="0,0,0,25"/>

                        <StackPanel Margin="0,0,0,18">
                            <TextBlock Text="Име на собственик" FontWeight="SemiBold" FontSize="13" Foreground="#64748B" Margin="0,0,0,8"/>
                            <TextBox x:Name="ownerNameTxtBox" 
                                     IsReadOnly="True" 
                                     Style="{StaticResource RoundedTextBox}" 
                                     Height="42" VerticalContentAlignment="Center"
                                     Padding="12,0" Background="#F8FAFC"
                                     FontSize="15" FontWeight="SemiBold" Foreground="#1E293B"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,18">
                            <TextBlock Text="Телефон за връзка" FontWeight="SemiBold" FontSize="13" Foreground="#64748B" Margin="0,0,0,8"/>
                            <TextBox x:Name="ownerPhoneTxtBox" 
                                     IsReadOnly="True" 
                                     Style="{StaticResource RoundedTextBox}" 
                                     Height="42" VerticalContentAlignment="Center"
                                     Padding="12,0" Background="#F8FAFC"
                                     FontSize="15" FontWeight="SemiBold" Foreground="#1E293B"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,18">
                            <TextBlock Text="Брой живущи" FontWeight="SemiBold" FontSize="13" Foreground="#64748B" Margin="0,0,0,8"/>
                            <TextBox x:Name="residentCountTxtBox" 
                                     IsReadOnly="True" 
                                     Style="{StaticResource RoundedTextBox}" 
                                     Height="42" VerticalContentAlignment="Center"
                                     Padding="12,0" Background="#F8FAFC"
                                     FontSize="15" FontWeight="SemiBold" Foreground="#1E293B"/>
                        </StackPanel>

                        <TextBlock Text="ℹ️ Информацията е само за четене" 
                                   FontSize="11" Foreground="#94A3B8" 
                                   FontStyle="Italic" Margin="0,20,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" CornerRadius="15" Background="White" Padding="25" BorderBrush="#E2E8F0" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" Opacity="0.05" ShadowDepth="4" Color="#64748B"/>
                    </Border.Effect>

                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="📝 Допълнителни бележки" 
                                   FontWeight="Bold" FontSize="18" 
                                   Foreground="#1E293B" Margin="0,0,0,15"/>

                        <Border Grid.Row="2" CornerRadius="8" Background="#FFFDF2" BorderBrush="#FDE68A" BorderThickness="1">
                            <TextBox x:Name="NotesTextBox" 
                             Style="{StaticResource RoundedTextBox}" 
                             FontFamily="Segoe UI"
                             FontSize="14"
                             Padding="15"
                             BorderThickness="0" 
                             Background="Transparent"
                             TextWrapping="Wrap" 
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"/>
                        </Border>
                    </DockPanel>
                </Border>
            </Grid>
        </DockPanel>
    </Grid>
</Window>