<Window x:Class="Syndiceo.Windows.WhatsNewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Какво ново" Height="672" Width="846"
        WindowStartupLocation="CenterScreen" WindowStyle="None" 
        AllowsTransparency="True" Background="Transparent" Loaded="Window_Loaded">

    <Border CornerRadius="20" BorderThickness="1" BorderBrush="#30FFFFFF">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#F8FAFC" Offset="0"/>
                <GradientStop Color="#F1F5F9" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>

        <Border.Effect>
            <DropShadowEffect BlurRadius="25" Opacity="0.2" Direction="270" ShadowDepth="5"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="140"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="80"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" CornerRadius="20,20,0,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#2563EB" Offset="0"/>
                        <GradientStop Color="#7C3AED" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <StackPanel VerticalAlignment="Center" Margin="30,0,0,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="Syndiceo" 
                                   FontSize="12" 
                                   FontWeight="Bold" 

                                   Foreground="#A5B4FC" 
                                   Opacity="0.8"/>
                        <TextBlock x:Name="version" 
                                   Text="v1.2.0" 
                                   FontSize="11" 
                                   Foreground="#C7D2FE" 
                                   Margin="10,1,0,0" 
                                   VerticalAlignment="Center" 
                                   Opacity="0.6"/>
                    </StackPanel>

                    <TextBlock Text="УСПЕШНО ОБНОВЛЕНИЕ" 
                               FontSize="32" 
                               FontWeight="Black" 
                               Foreground="White" 
                               Margin="0,0,0,2"/>

                    <TextBlock Text="КАКВО Е НОВО?" 
                               FontSize="13" 
                               FontWeight="Bold" 
                               Foreground="#E0E7FF" 
                               Opacity="0.9"
                               Margin="2,0,0,0"/>
                </StackPanel>
            </Border>

            <ScrollViewer Grid.Row="1" Margin="20,15,20,10" VerticalScrollBarVisibility="Hidden">
                <StackPanel>
                    <Border Background="White" CornerRadius="12" Padding="15" Margin="0,5,0,10">
                        <StackPanel>
                            <TextBlock Text="🎨 ИНТЕРФЕЙС" FontSize="11" FontWeight="Bold" Foreground="#6366F1" Margin="0,0,0,8"/>
                            <TextBlock Text="Изцяло нов визуален дизайн" FontSize="15" FontWeight="SemiBold" Foreground="#1E293B"/>
                            <TextBlock Text="Модернизиран изглед на таблиците и отчетите с акцент върху четливостта и по-бързото сканиране на данните." FontSize="13" Foreground="#64748B" TextWrapping="Wrap" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Background="White" CornerRadius="12" Padding="15" Margin="0,5,0,10">
                        <StackPanel>
                            <TextBlock Text="🛡️ СИГУРНОСТ" FontSize="11" FontWeight="Bold" Foreground="#10B981" Margin="0,0,0,8"/>
                            <TextBlock Text="Повишена защита на данните" FontSize="15" FontWeight="SemiBold" Foreground="#1E293B"/>
                            <TextBlock Text="Въведени са нови механизми за архивиране и валидация, гарантиращи безопасността на Вашата информация." FontSize="13" Foreground="#64748B" TextWrapping="Wrap" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Background="White" CornerRadius="12" Padding="15" Margin="0,5,0,10">
                        <StackPanel>
                            <TextBlock Text="✨ НОВИ ФУНКЦИИ" FontSize="11" FontWeight="Bold" Foreground="#8B5CF6" Margin="0,0,0,8"/>
                            <TextBlock Text="Улеснено управление" FontSize="15" FontWeight="SemiBold" Foreground="#1E293B"/>
                            <TextBlock Text="Автоматично попълване при добавяне на нов адрес и възможност за пълно премахване на неизползвани категории." FontSize="13" Foreground="#64748B" TextWrapping="Wrap" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Background="White" CornerRadius="12" Padding="15" Margin="0,5,0,10">
                        <StackPanel>
                            <TextBlock Text="🛠️ ПОДОБРЕНИЯ" FontSize="11" FontWeight="Bold" Foreground="#F59E0B" Margin="0,0,0,8"/>
                            <TextBlock Text="Fix: Стабилност на системата" FontSize="15" FontWeight="SemiBold" Foreground="#1E293B"/>
                            <TextBlock Text="Отстранени са критични грешки при затваряне на прозорци и са оптимизирани процесите по редакция." FontSize="13" Foreground="#64748B" TextWrapping="Wrap" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Button Grid.Row="2" Content="РАЗБРАХ" Click="OkButton_Click"
                    Margin="30,10,30,20" Background="#1E293B" Foreground="White" 
                    FontSize="14" FontWeight="Bold" Cursor="Hand" Style="{StaticResource CleanIconButton}">
            </Button>
        </Grid>
    </Border>
</Window>