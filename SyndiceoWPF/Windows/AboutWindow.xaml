<Window x:Class="Syndiceo.Windows.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Относно Syndiceo" 
        Height="532" Width="786"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        WindowStyle="None"
        Background="Transparent"
                Icon="pack://application:,,,/Resources/Ico/logo256.ico">

    <Grid Margin="20">
        <Border Background="White" CornerRadius="28" BorderBrush="#F1F5F9" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="45" Opacity="0.12" ShadowDepth="12" Color="#1E293B"/>
            </Border.Effect>

            <Grid>
                <Border VerticalAlignment="Top" Height="150" CornerRadius="28,28,0,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#F0F4FF" Offset="0"/>
                            <GradientStop Color="#FFFFFF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <Grid Margin="45,40">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,30">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Syndiceo" FontSize="44" FontWeight="Black" 
                                       Foreground="#0F172A"/>

                            <Border Background="{StaticResource PrimaryHover}" CornerRadius="8" Padding="12,5" Margin="18,0,0,0" VerticalAlignment="Center">
                                <TextBlock x:Name="SyndiceoVersion" Text="v1.0.0" FontSize="11" 
                                           FontWeight="ExtraBold" Foreground="White"/>
                            </Border>
                        </StackPanel>
                        <TextBlock Text="УПРАВЛЕНИЕ И КОНТРОЛ НА ЕТАЖНАТА СОБСТВЕНОСТ" FontSize="15" 
                                   Foreground="#64748B" Margin="2,2,0,0" FontWeight="Medium"/>
                    </StackPanel>

                    <Border Grid.Row="1" Background="#F8FAFC" CornerRadius="24" BorderBrush="#E2E8F0" BorderThickness="1">
                        <Grid Margin="25">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Width="115" Height="115" Background="White" 
                                    CornerRadius="22" BorderBrush="#EDF2F7" BorderThickness="1.5">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="15" Opacity="0.05" ShadowDepth="4" Color="#64748B"/>
                                </Border.Effect>
                                <Image Source="/Resources/blacknobackground.png" Margin="20" Stretch="Uniform"/>
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="35,0,0,0">
                                <TextBlock Text="РАЗРАБОТКА" FontSize="11" FontWeight="Black" 
                                           Foreground="{StaticResource PrimaryHover}" Margin="0,0,0,5"/>

                                <TextBlock Text="NYXON" FontSize="28" FontWeight="Black" 
                                           Foreground="#1E293B" Margin="0,0,0,2"/>

                                <TextBlock Text="nyxonstudios@gmail.com" FontSize="14" Foreground="#64748B" 
                                           Margin="0,0,0,25" FontWeight="SemiBold"/>

                                <Button x:Name="OpenWebsite" Click="OpenWebsite_Click"
                                        Cursor="Hand" Width="200" Height="48" HorizontalAlignment="Left"
                                        Style="{StaticResource MainButtonStyle}">
                                    <TextBlock Text="ПОСЕТЕТЕ САЙТА" FontSize="12" FontWeight="Bold"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="2" Margin="0,35,0,0">
                        <StackPanel HorizontalAlignment="Center" Orientation="Horizontal" Opacity="0.7">
                            <TextBlock Text="© 2026 Syndiceo." FontSize="12" Foreground="#64748B" FontWeight="Medium"/>
                            <TextBlock Text=" Всички права запазени " FontSize="12" Foreground="#64748B" FontWeight="Medium" Margin="4,0"/>
                        </StackPanel>
                    </Grid>
                </Grid>

                <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top" 
                        Margin="20" Background="Transparent" BorderBrush="Transparent"
                        Foreground="#CBD5E1" FontSize="18" Cursor="Hand" x:Name="CloseButton"
                        Click="CloseButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>