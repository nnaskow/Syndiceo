<Window x:Class="Syndiceo.Windows.AddNoteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Syndiceo"
        mc:Ignorable="d"
        Title="Добави бележка"
        MinWidth="450" MinHeight="400"
        Width="670" Height="449"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize" 
        Icon="pack://application:,,,/Resources/Ico/logo256.ico"
        Loaded="Window_Loaded" Background="#F8FAFC">
    <Grid Margin="0">
        <Border Margin="30" CornerRadius="15" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" VerticalAlignment="Stretch">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" Opacity="0.1" ShadowDepth="2" Color="#64748B"/>
            </Border.Effect>

            <Grid Margin="25">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock Text="📝 Нова бележка" 
                               FontFamily="Segoe UI" FontWeight="Bold" FontSize="22" 
                               HorizontalAlignment="Left" Foreground="#1E293B"/>
                    <TextBlock Text="Въведете важна информация за този обект" 
                               FontSize="13" Foreground="#64748B" Margin="2,5,0,0"/>
                    <Separator Margin="0,15,0,0" Background="#F1F5F9" Height="1"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="5,0,0,8">
                    <TextBlock Text="Съдържание на бележката" FontWeight="SemiBold" 
                               FontSize="12" Foreground="#475569"/>
                </StackPanel>

                <Border Grid.Row="2" CornerRadius="8" Background="#FFFDF2" BorderBrush="#FDE68A" BorderThickness="1">
                    <TextBox x:Name="NoteTextBox" 
                             Style="{StaticResource RoundedTextBox}" 
                             KeyDown="NoteTextBox_KeyDown"
                             FontFamily="Segoe UI"
                             FontSize="14"
                             Padding="15"
                             BorderThickness="0" 
                             Background="Transparent"
                             TextWrapping="Wrap" 
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"/>
                </Border>

                <StackPanel Grid.Row="3" Margin="0,25,0,0">
                    <Button Style="{StaticResource MainButtonStyle}" 
                            Content="💾 Запази бележката" 
                            Width="220" Height="48" 
                            FontSize="15" FontWeight="SemiBold"
                            HorizontalAlignment="Center" 
                            Cursor="Hand"
                            Click="SaveNoteButton_Click">
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>