<Window x:Class="Archon.TaxesHelper"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Помощник за такси" Height="450" Width="400"
        WindowStartupLocation="Manual"
        ResizeMode="NoResize"
        FontFamily="Calibri"        
        Icon="pack://application:,,,/Resources/helper.ico"
        Visibility="Collapsed">
    <ScrollViewer Margin="10">
        <StackPanel Orientation="Vertical" >

            <TextBlock Text="Неразпределени разходи" FontWeight="Bold" FontSize="16" Margin="0,10,0,5"/>
            <ItemsControl x:Name="ExpenseCategoriesPanel">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border CornerRadius="8" BorderBrush="#FF5555" BorderThickness="1" Background="#FFE6E6" Padding="5" Margin="0,2">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Name}" Width="200" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Amount}" HorizontalAlignment="Right"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <TextBlock Text="Неразпределени приходи" FontWeight="Bold" FontSize="16" Margin="0,0,0,5"/>
            <ItemsControl x:Name="IncomeCategoriesPanel" Margin="0,0,0,10">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border CornerRadius="8" BorderBrush="#007ACC" BorderThickness="1" Background="#E6F0FA" Padding="5" Margin="0,2">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Name}" Width="200" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Amount}" HorizontalAlignment="Right"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </ScrollViewer>
</Window>
