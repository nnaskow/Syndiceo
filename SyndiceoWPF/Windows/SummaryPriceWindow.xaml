<Window x:Class="Syndiceo.Windows.SummaryPriceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Syndiceo"
        Icon="pack://application:,,,/Resources/Ico/logo256.ico"
        mc:Ignorable="d"
        Title="Плащане"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="ToolWindow"
        Height="539"
        Width="500"
        Topmost="True"
        ShowInTaskbar="False"
        Background="#F1F5F9"
        Closing="Window_Closing"
        Loaded="Window_Loaded">

    <Grid>

        <Border Margin="20" Background="White" CornerRadius="15" BorderBrush="#E2E8F0" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Opacity="0.1" ShadowDepth="2" Color="#64748B"/>
            </Border.Effect>

            <StackPanel Margin="20" VerticalAlignment="Center">

                <TextBlock Text="ДЕТАЙЛИ ЗА ПЛАЩАНЕ" 
                           FontSize="12" FontWeight="Bold" Foreground="#64748B" 
                           HorizontalAlignment="Center" Margin="0,0,0,15" />

                <Border Background="#F8FAFD" CornerRadius="10" Padding="15" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Обща дължима сума" FontSize="13" Foreground="#64748B" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TotalAmountTextBlock"
                                   Text="0.00"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="#1E293B"
                                   HorizontalAlignment="Center"
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                        <TextBlock Text="Платено" FontSize="12" Foreground="#64748B" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="CurrentPaidTextBlock" Text="0.00" FontSize="16" FontWeight="Bold" Foreground="#16A34A" Margin="0,4,0,0"/>
                    </StackPanel>

                    <Separator Grid.Column="1" Width="1" Height="30" Background="#E2E8F0" Margin="15,0"/>

                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                        <TextBlock Text="Остава" FontSize="12" Foreground="#64748B" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="RemainingSum" Text="0.00" FontSize="16" FontWeight="Bold" Foreground="#DC2626" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>

                <Separator Background="#F1F5F9" Margin="0,0,0,20"/>

                <StackPanel Margin="0,0,0,25">
                    <TextBlock Text="Въведете сума за внасяне" FontSize="13" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,8" HorizontalAlignment="Center"/>
                    <Grid HorizontalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="45"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="PaidAmountTextBox" 
                                 KeyDown="PaidAmountTextBox_KeyDown"
                                 Height="42" 
                                 Style="{StaticResource RoundedTextBox}"
                                 FontSize="18" 
                                 FontWeight="Bold"
                                 TextAlignment="Center"
                                 VerticalContentAlignment="Center"
                                 Background="#F1F5F9"/>

                        <Button Grid.Column="1" 
                                x:Name="LastTransactionsButton" 
                                Click="LastTransactionsButton_Click"
                                Content="📖" 
                                ToolTip="История на плащанията" 
                                Style="{StaticResource SmallButtonStyle}"
                                Width="38" Height="42" 
                                Margin="7,0,0,0" 
                                FontSize="16"/>
                    </Grid>
                </StackPanel>

                <Button x:Name="SavePayment"
                        Content="Потвърди плащането" 
                        Click="SavePayment_Click"
                        Width="240" 
                        Height="48"
                        FontWeight="Bold"
                        FontSize="16"
                        Style="{StaticResource MainButtonStyle}"
                        Cursor="Hand"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>