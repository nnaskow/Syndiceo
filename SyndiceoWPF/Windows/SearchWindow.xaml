<Window x:Class="Syndiceo.Windows.SearchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Търсене"
        Height="550" Width="700"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Icon="pack://application:,,,/Resources/Ico/logo256.ico"
        Background="#F8FAFC"
        Loaded="Window_Loaded">

    <Grid Margin="20">
        <Border CornerRadius="15" Background="White" BorderBrush="#E2E8F0" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Opacity="0.05" ShadowDepth="2" Color="#64748B"/>
            </Border.Effect>

            <DockPanel Margin="20">
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,15">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔍" FontSize="18" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="SearchResultsLabel"
                                   Text="Резултати от търсенето"
                                   FontFamily="Segoe UI"
                                   FontWeight="Bold"
                                   FontSize="18"
                                   Foreground="#1E293B"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <Separator Margin="0,12,0,0" Background="#F1F5F9" Height="1"/>
                </StackPanel>

                <DataGrid x:Name="SearchResultsDataGrid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False" 
                          IsReadOnly="True"
                          RowHeaderWidth="0"
                          GridLinesVisibility="None"
                          Background="Transparent"
                          BorderThickness="0"
                          FontSize="14"
                          FontFamily="Segoe UI"
                          SelectionUnit="FullRow"
                          HorizontalScrollBarVisibility="Disabled">

                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#64748B"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="10,8"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#F1F5F9"/>
                        </Style>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding" Value="10"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#EFF6FF"/>
                                    <Setter Property="Foreground" Value="#2563EB"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Собственик" Binding="{Binding OwnerName}" Width="1.5*"/>
                        <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="1*"/>
                        <DataGridTextColumn Header="Адрес на обекта" Binding="{Binding FullAddress}" Width="2*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>
    </Grid>
</Window>