<Window x:Class="Syndiceo.Windows.SearchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Търсене"
        Height="487" Width="588"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Icon="pack://application:,,,/Resources/Ico/logo128.ico"
        FontFamily="Calibri"
        Loaded="Window_Loaded">

    <Grid Margin="20" Background="White">
        <!-- Watermark Logo -->
        <Image Source="/Resources/logo.png"
               Opacity="0.05"
               Stretch="Uniform"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               Panel.ZIndex="0"/>

        <Border CornerRadius="10" Padding="15"
                BorderBrush="#DDD" BorderThickness="1"
                Background="Transparent">
            <StackPanel>
                <!-- Label над DataGrid -->
                <TextBlock x:Name="SearchResultsLabel"
                           Text="Намерени резултати за:"
                           FontWeight="Bold"
                           FontSize="16"
                           Margin="0,0,0,10"
                           Foreground="#FF001C2D"/>

                <!-- DataGrid с резултати -->
                <DataGrid x:Name="SearchResultsDataGrid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False" Background="Transparent"
                          IsReadOnly="True"
                          FontFamily="Calibri"
                          RowHeaderWidth="0"
                          Height="350">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Собственик" Binding="{Binding OwnerName}" Width="150"/>
                        <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="120"/>
                        <DataGridTextColumn Header="Адрес" Binding="{Binding FullAddress}" Width="200"/>
                    </DataGrid.Columns>

                </DataGrid>
            </StackPanel>
        </Border>
    </Grid>
</Window>
