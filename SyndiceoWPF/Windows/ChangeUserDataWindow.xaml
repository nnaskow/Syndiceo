<Window x:Class="Syndiceo.Windows.ChangeUserDataWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Настройки на профила"
        MinWidth="450" MinHeight="400"
        Width="500" Height="550"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Icon="pack://application:,,,/Resources/Ico/logo256.ico"
        Loaded="Window_Loaded"
        Closing="Window_Closing" Background="#F8FAFC">

    <Grid>
        <Border Margin="25" CornerRadius="15" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" VerticalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Opacity="0.08" ShadowDepth="2" Color="#64748B"/>
            </Border.Effect>

            <StackPanel Margin="25">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
                    <TextBlock Text="👤" FontSize="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Промяна на данни" 
                               FontFamily="Segoe UI" FontWeight="Bold" FontSize="20" 
                               Foreground="#1E293B" VerticalAlignment="Center"/>
                </StackPanel>

                <Separator Margin="0,5,0,20" Background="#F1F5F9" Height="1"/>

                <Border Background="#FFFBEB" CornerRadius="8" Padding="10" Margin="0,0,0,15" BorderBrush="#FEF3C7" BorderThickness="1">
                    <TextBlock Text="За ваша сигурност, моля потвърдете промените с парола." 
                               FontSize="11" Foreground="#92400E" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                </Border>

                <Grid x:Name="ChangeNameGrid" Visibility="Collapsed">
                    <StackPanel>
                        <Label Content="Парола за потвърждение:" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,2"/>
                        <PasswordBox x:Name="ConfirmPasswordForName" Style="{StaticResource RoundedPasswordBox}" Height="38" Margin="0,0,0,12" VerticalContentAlignment="Center"/>

                        <Label Content="Ново име:" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,2"/>
                        <TextBox x:Name="NewNameTextBox" Style="{StaticResource RoundedTextBox}" Height="38" Margin="0,0,0,10" VerticalContentAlignment="Center"/>

                        <Button x:Name="changeNameButton" Style="{StaticResource MainButtonStyle}" 
                                Content="💾 Запази името" Click="changeNameButton_Click"
                                Width="200" Height="45" FontWeight="SemiBold"
                                HorizontalAlignment="Center" Margin="0,15,0,0"/>
                    </StackPanel>
                </Grid>

                <Grid x:Name="ChangeUsernameGrid" Visibility="Collapsed">
                    <StackPanel>
                        <Label Content="Парола за потвърждение:" FontWeight="SemiBold" Foreground="#475569"/>
                        <PasswordBox x:Name="ConfirmPasswordForUsername" Style="{StaticResource RoundedPasswordBox}" Height="38" Margin="0,0,0,12" VerticalContentAlignment="Center"/>

                        <Label Content="Ново потребителско име:" FontWeight="SemiBold" Foreground="#475569"/>
                        <TextBox x:Name="NewUsernameTextBox" Style="{StaticResource RoundedTextBox}" Height="38" Margin="0,0,0,10" VerticalContentAlignment="Center"/>

                        <Button x:Name="changeUsernameButton" Style="{StaticResource MainButtonStyle}" 
                                Content="💾 Смяна на Username" Click="changeUsernameButton_Click"
                                Width="240" Height="45" FontWeight="SemiBold"
                                HorizontalAlignment="Center" Margin="0,15,0,0"/>
                    </StackPanel>
                </Grid>

                <Grid x:Name="ChangeEmailGrid" Visibility="Collapsed">
                    <StackPanel>
                        <Label Content="Парола за потвърждение:" FontWeight="SemiBold" Foreground="#475569"/>
                        <PasswordBox x:Name="ConfirmPasswordForEmail" Style="{StaticResource RoundedPasswordBox}" Height="38" Margin="0,0,0,12" VerticalContentAlignment="Center"/>

                        <Label Content="Нов имейл адрес:" FontWeight="SemiBold" Foreground="#475569"/>
                        <TextBox x:Name="NewEmailTextBox" Style="{StaticResource RoundedTextBox}" Height="38" Margin="0,0,0,10" VerticalContentAlignment="Center"/>

                        <Button Name="changeEmailButton" Style="{StaticResource MainButtonStyle}" 
                                Content="✉️ Смяна на имейл" Click="changeEmailButton_Click"
                                Width="200" Height="45" FontWeight="SemiBold"
                                HorizontalAlignment="Center" Margin="0,15,0,0"/>
                    </StackPanel>
                </Grid>

                <Grid x:Name="ChangePasswordGrid" Visibility="Collapsed">
                    <StackPanel>
                        <Label Content="Стара парола:" FontWeight="SemiBold" Foreground="#475569"/>
                        <PasswordBox x:Name="OldPasswordBox" Style="{StaticResource RoundedPasswordBox}" Height="38" Margin="0,0,0,12" VerticalContentAlignment="Center"/>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                <Label Content="Нова парола:" FontWeight="SemiBold" Foreground="#475569"/>
                                <PasswordBox x:Name="NewPasswordBox" Style="{StaticResource RoundedPasswordBox}" Height="38" VerticalContentAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                <Label Content="Потвърди:" FontWeight="SemiBold" Foreground="#475569"/>
                                <PasswordBox x:Name="ConfirmNewPasswordBox" Style="{StaticResource RoundedPasswordBox}" Height="38" VerticalContentAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <Button Name="changePasswordButton" Style="{StaticResource MainButtonStyle}" 
                                Content="🔐 Обнови паролата" Click="changePasswordButton_Click"
                                Width="220" Height="45" FontWeight="SemiBold"
                                HorizontalAlignment="Center" Margin="0,15,0,0"/>
                    </StackPanel>
                </Grid>

            </StackPanel>
        </Border>
    </Grid>
</Window>