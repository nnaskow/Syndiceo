<Window x:Class="Syndiceo.Windows.AddToDBWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Нов адрес"
        MinWidth="850" MinHeight="621"
        Width="850" Height="637"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Icon="pack://application:,,,/Resources/Ico/logo128.ico"
        Loaded="Window_Loaded" Background="{StaticResource AppBackground}">

    <Grid Margin="20" Background="{StaticResource AppBackground}">
        <!-- Воден знак -->
        <Image Source="/Resources/logo.png"
               Opacity="0.05"
               Stretch="Uniform"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               Panel.ZIndex="0" Width="522"/>

        <!-- Основно съдържание -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- Ляв панел: Адресна информация -->
            <Border Grid.Column="0" Grid.Row="0" CornerRadius="10" Padding="15" Margin="0,0,10,0" 
                    BorderBrush="#DDD" BorderThickness="1" VerticalAlignment="Stretch">
                <StackPanel>
                    <TextBlock Text="Добавяне на нов адрес" 
                               FontFamily="Calibri" FontWeight="Bold" FontSize="18" 
                               HorizontalAlignment="Center" Foreground="#333"/>
                    <Separator Margin="0,10,0,10"/>

                    <!-- Адрес -->
                    <Label Content="Адрес:" FontWeight="Bold" FontSize="14"/>
                    <ComboBox Style="{StaticResource RoundComboBox}" 
                              x:Name="AddressComboBox" DisplayMemberPath="Street" 
                              IsEditable="True" Height="30" 
                              DropDownOpened="AddressComboBox_DropDownOpened"/>

                    <!-- Блок -->
                    <Label Content="Блок:" Margin="0,10,0,0" FontWeight="Bold" FontSize="14"/>
                    <ComboBox Style="{StaticResource RoundComboBox}" 
                              x:Name="BlockComboBox" DisplayMemberPath="BlockName" 
                              IsEditable="True" Height="30" 
                              DropDownOpened="BlockComboBox_DropDownOpened"/>

                    <!-- Вход -->
                    <Label Content="Вход:" Margin="0,10,0,0" FontWeight="Bold" FontSize="14"/>
                    <ComboBox Style="{StaticResource RoundComboBox}" 
                              x:Name="EntranceComboBox" DisplayMemberPath="EntranceName" 
                              IsEditable="True" Height="30" 
                              DropDownOpened="EntranceComboBox_DropDownOpened"/>

                    <!-- Апартамент и живущи -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                        <StackPanel Orientation="Vertical" Margin="0,0,10,0">
                            <Label Content="Апартамент №:" FontWeight="Bold" FontSize="14"/>
                            <TextBox Style="{StaticResource RoundedTextBox}" 
                                     x:Name="ApartmentNumberTextBox" 
                                     Height="35" Width="120" TextAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Orientation="Vertical">
                            <Label Content="Брой живущи:" FontWeight="Bold" FontSize="14"/>
                            <TextBox Style="{StaticResource RoundedTextBox}" 
                                     x:Name="ResidentsCountTextBox" 
                                     Height="35" Width="120" TextAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Бележка -->
                    <Label Content="Бележка:" Margin="0,15,0,0" FontWeight="Bold" FontSize="14"/>
                    <TextBox Style="{StaticResource RoundedTextBox}" 
                             x:Name="NoteTextBox" Height="80" 
                             TextWrapping="Wrap" AcceptsReturn="True"/>
                    <TextBlock Text="*Това поле не е задължително" 
                               Foreground="Gray" FontStyle="Italic" FontSize="12" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <!-- Разделител -->
            <Border Grid.Column="1" Grid.Row="0" Width="1" Background="#DDD" VerticalAlignment="Stretch"/>

            <!-- Десен панел: Контакти -->
            <Border Grid.Column="2" Grid.Row="0" CornerRadius="10" Padding="15" Margin="10,0,0,0" 
                    BorderBrush="#DDD" BorderThickness="1" VerticalAlignment="Center" Height="228">
                <StackPanel>
                    <TextBlock Text="Данни за контакт" 
                               FontFamily="Calibri" FontWeight="Bold" FontSize="18" 
                               HorizontalAlignment="Center" Foreground="#333"/>
                    <Separator Margin="0,10,0,10"/>

                    <Label Content="Име на собственик:" FontWeight="Bold" FontSize="14"/>
                    <TextBox Style="{StaticResource RoundedTextBox}" 
                             x:Name="ownerNameTxtBox" Height="35" TextAlignment="Center"/>

                    <Label Content="Телефон на собственик:" Margin="0,10,0,0" FontWeight="Bold" FontSize="14"/>
                    <TextBox Style="{StaticResource RoundedTextBox}" 
                             x:Name="ownerPhoneNumberTxtBox" Height="35" TextAlignment="Center" 
                             TextChanged="ownerPhoneNumberTxtBox_TextChanged"/>
                </StackPanel>
            </Border>

            <!-- Бутон под целия десен панел -->
            <Button Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
        Style="{StaticResource MainButtonStyle}" 
        Content="➕ Добави"
        Height="50"
        HorizontalAlignment="Stretch"
        Margin="0,15,0,0"
        Click="Button_Click"/>
        </Grid>

    </Grid>
</Window>
