<Window x:Class="Syndiceo.Windows.ArchiveWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Syndiceo"
        mc:Ignorable="d"
        Title="Архивиране на данни" 
        Height="321" Width="596"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Icon="pack://application:,,,/Resources/Ico/logo256.ico"
        FontFamily="Segoe UI" 
        Loaded="Window_Loaded" 
        Focusable="True" 
        Background="#F8FAFC">

    <Grid>
        <Border Margin="25" CornerRadius="15" Background="White" BorderBrush="#E2E8F0" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Opacity="0.05" ShadowDepth="2" Color="#64748B"/>
            </Border.Effect>

            <StackPanel Margin="25" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
                    <TextBlock x:Name="archiveLabel" 
                               Text="Изберете място за архив"
                               FontSize="18" FontWeight="Bold" 
                               Foreground="#1E293B" VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock Text="Вашите данни ще бъдат експортирани в избраната директория." 
                           FontSize="11" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <Grid Margin="0,0,0,20">
                    <TextBox x:Name="ArchivePathTextBox"
                             Style="{StaticResource RoundedTextBox}"
                             Height="40"
                             Padding="10,0"
                             VerticalContentAlignment="Center"
                             IsReadOnly="True"
                             Background="#F1F5F9"
                             BorderBrush="#CBD5E0"
                             Foreground="#475569"
                             FontSize="12"
                             Text="Моля, изберете папка..."/>
                </Grid>

                <Button Style="{StaticResource MainButtonStyle}" 
                        Content="📁 Изберете дестинация" 
                        Width="220" Height="48" 
                        FontSize="14" FontWeight="SemiBold"
                        HorizontalAlignment="Center"
                        Cursor="Hand"
                        Click="SelectFolderButton_Click">
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>