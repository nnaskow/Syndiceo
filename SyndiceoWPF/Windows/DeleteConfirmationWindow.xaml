<Window x:Class="Syndiceo.Windows.DeleteConfirmationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Потвърждение за изтриване" 
        Height="280" Width="514"
        WindowStartupLocation="CenterOwner" 
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Border Margin="10" CornerRadius="15" Background="White" BorderBrush="#E2E8F0" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Opacity="0.2" Direction="270" ShadowDepth="2" Color="Black"/>
        </Border.Effect>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Height="4" Background="#E74C3C" CornerRadius="2" VerticalAlignment="Top" Margin="0,0,0,15"/>

            <StackPanel Grid.Row="1" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="⚠️" FontSize="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Потвърждение за изтриване" 
                               FontSize="18" FontWeight="Bold" Foreground="#1E293B" 
                               FontFamily="Segoe UI" VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock Text="Сигурни ли сте, че искате да премахнете този запис? Това действие е необратимо." 
                           TextWrapping="Wrap" FontSize="14" Foreground="#64748B" 
                           LineHeight="20" Margin="0,0,0,15"/>

                <CheckBox x:Name="DeleteRelatedCheckBox" 
                          Content="Изтрий и всички свързани записи" 
                          FontSize="13" Foreground="#475569" FontWeight="SemiBold"
                          Cursor="Hand" VerticalContentAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Content="Отказ" Width="90" Height="38" 
                        Margin="5" IsCancel="True" Click="Button_Click"
                        Background="#F1F5F9" Foreground="#475569" 
                        BorderThickness="0" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button Content="Изтрий" Width="110" Height="38" 
                        Margin="5" IsDefault="True" Click="Yes_Click"
                        Background="#E74C3C" Foreground="White" 
                        FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>