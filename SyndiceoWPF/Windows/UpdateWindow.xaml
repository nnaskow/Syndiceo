<Window x:Class="Syndiceo.Windows.UpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Проверка за актуализации"
        Width="560" Height="450"
        MinWidth="400" MinHeight="300"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        FontFamily="Segoe UI"
        Background="#F9FAFB"
        Icon="pack://application:,,,/Resources/Ico/logo128.ico"
        Loaded="Window_Loaded">

    <Grid Margin="20">

        <!-- Watermark (лека, полупрозрачна) -->
        <Image Source="/Resources/logo.png" Opacity="0.03" Stretch="Uniform"
               HorizontalAlignment="Center" VerticalAlignment="Center" Panel.ZIndex="0"/>
        <Border CornerRadius="16" Background="Transparent" Padding="25" BorderBrush="#DDD" BorderThickness="1" Panel.ZIndex="1" >
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Buttons -->
                    <!-- Header -->
                    <RowDefinition Height="*"/>
                    <!-- Status -->
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,10">
                    <TextBlock Text="Проверка за актуализации" FontSize="26" FontWeight="Bold" Foreground="#222" HorizontalAlignment="Center"/>
                    <Separator Width="400" HorizontalAlignment="Center" Margin="0,12" Background="#CCC"/>
                </StackPanel>

                <!-- Status / Progress -->
                <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,10,0,10">
                    <TextBlock x:Name="StatusTextBlock" Text="Проверка за нови версии..." 
                               FontSize="18" FontWeight="SemiBold" TextAlignment="Center" Foreground="#555" Margin="0,10"/>

                    <!-- Модерен ProgressBar с анимация -->
                    <Grid Width="400" Height="25" Margin="0,15">
                        <Border CornerRadius="12" Background="#EEE" />

                        <!-- Rectangle с име на ScaleTransform -->
                        <Rectangle x:Name="CheckProgressBarIndicator" Fill="#4CAF50" RadiusX="12" RadiusY="12" Width="400">
                            <Rectangle.RenderTransform>
                                <ScaleTransform x:Name="ProgressScale" ScaleX="0" CenterX="0" />
                            </Rectangle.RenderTransform>
                        </Rectangle>

                        <TextBlock x:Name="ProgressText" Text="0%" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="#333"/>
                    </Grid>


                    <!-- Текуща версия -->
                    <TextBlock x:Name="CurrentVersionTextBlock" Text="Текуща версия:" 
                               FontSize="16" FontWeight="Bold" TextAlignment="Center" Foreground="#333" Margin="0,15,0,0" FontStyle="Italic"/>
                </StackPanel>

                <!-- Buttons -->
                <StackPanel Grid.Row="2" Orientation="Vertical" HorizontalAlignment="Center" Margin="0,5,0,0" >
                    <Button x:Name="CheckAgainButton" Content="🔄 Провери отново" Width="200" Height="42" 
                           Foreground="White" FontWeight="SemiBold" BorderThickness="0"
                            Cursor="Hand" Margin="0,0,0,8" Click="CheckAgainButton_Click"   Style="{StaticResource MainButtonStyle}"/>

                    <Button x:Name="UpdateButton" Content="⬇️ Актуализирай" Width="200" Height="42" Style="{StaticResource MainButtonStyle}"
                            Foreground="White" FontWeight="SemiBold" BorderThickness="0"
                            Cursor="Hand" IsEnabled="False" Opacity="0.475" Click="UpdateButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Основна рамка -->
    </Grid>
</Window>
