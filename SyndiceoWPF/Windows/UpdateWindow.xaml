<Window x:Class="Syndiceo.Windows.UpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Syndiceo"
        mc:Ignorable="d"
        Title="Проверка за актуализации"
        Height="612"
        Width="932"
        MinHeight="520"
        MinWidth="760"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Background="#F1F5F9" 
        Icon="pack://application:,,,/Resources/Ico/logo256.ico"
        Loaded="Window_Loaded">

    <Grid Margin="20">
        <Border Background="White"
                CornerRadius="24"
                BorderBrush="#E6ECF5"
                BorderThickness="1"
                Padding="24">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="18"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="18"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="18"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="#1E293B" 
                        CornerRadius="20"
                        Padding="24">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="18"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Width="64" Height="64" CornerRadius="16" Background="#16233B" Padding="10" VerticalAlignment="Center">
                            <Image Source="pack://application:,,,/Resources/Ico/logo256.ico" Stretch="Uniform"/>
                        </Border>

                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock Text="Актуализации" Foreground="White" FontSize="28" FontWeight="Bold"/>
                            <TextBlock Text="Поддържайте Syndiceo актуален, за да получавате най-новите функции и сигурност."
                                       Foreground="#B8C4D6" FontSize="14" Margin="0,6,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Background="#F8FAFD" CornerRadius="20" BorderBrush="#E6ECF5" BorderThickness="1" Padding="24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="16"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" HorizontalAlignment="Center">
                            <TextBlock x:Name="StatusTextBlock" Text="Проверка за нови версии..." FontSize="22" FontWeight="Bold" Foreground="#1E293B" TextAlignment="Center"/>
                        </StackPanel>

                        <Grid Grid.Row="2" Width="520" Height="28" HorizontalAlignment="Center">
                            <Border CornerRadius="14" Background="#EAF0F7"/>
                            <Border x:Name="CheckProgressBarIndicator" HorizontalAlignment="Left" Width="0" CornerRadius="14" Background="#2563EB">
                                <Border.RenderTransform>
                                    <ScaleTransform x:Name="ProgressScale" ScaleX="0" CenterX="0" />
                                </Border.RenderTransform>
                            </Border>
                            <TextBlock x:Name="ProgressText" Text="0%" FontWeight="Bold" Foreground="#1E293B" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </Grid>
                </Border>

                <Grid Grid.Row="4" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="240"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="240"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="White" CornerRadius="18" Padding="20" BorderBrush="#E6ECF5" BorderThickness="1">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="Текуща версия" FontSize="13" Foreground="#64748B" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="CurrentVersionTextBlock" Text="v1.0.0" FontSize="28" FontWeight="Bold" Foreground="#1E293B" Margin="0,8,0,0" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Background="White" CornerRadius="18" Padding="20" BorderBrush="#E6ECF5" BorderThickness="1">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="Налична версия" FontSize="13" Foreground="#64748B" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="LatestVersionTextBlock" Text="-" FontSize="28" FontWeight="Bold" Foreground="#16A34A" Margin="0,8,0,0" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Grid.Row="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Препоръчително е винаги да използвате най-новата версия." VerticalAlignment="Center" FontSize="13" Foreground="#64748B"/>

                    <Button Grid.Column="1" x:Name="CheckAgainButton" Content="🔄 Провери отново" Width="180" Height="42" Style="{StaticResource MainButtonStyle}" Click="CheckAgainButton_Click"/>
                    <Button Grid.Column="3" x:Name="UpdateButton" Content="⬇️ Актуализирай" Width="180" Height="42" Style="{StaticResource MainButtonStyle}" IsEnabled="False" Opacity="0.475" Click="UpdateButton_Click"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>