<Window x:Class="Syndiceo.Windows.EditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Syndiceo"
        mc:Ignorable="d"
        Title="Редактиране"
        MinWidth="400" MinHeight="300"
        Width="718" Height="556"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Icon="pack://application:,,,/Resources/Ico/logo128.ico"
        Loaded="Window_Loaded" Background="{StaticResource AppBackground}">

    <Grid Margin="20" Background="{StaticResource AppBackground}">
        <!-- Единен воден знак за цялото съдържание -->
        <Image Source="/Resources/logo.png"
               Opacity="0.05"
               Stretch="Uniform"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               Panel.ZIndex="0"/>

        <!-- Основно съдържание върху водния знак -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="221*" />
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="32*" />
                <ColumnDefinition Width="189*"/>
            </Grid.ColumnDefinitions>

            <!-- Лява страна -->
            <Border Grid.Column="0" CornerRadius="10" Padding="15" Margin="0,0,10,0" 
                    BorderBrush="#DDD" BorderThickness="1" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Редактиране на адрес" 
                               FontFamily="Calibri" FontWeight="Bold" FontSize="18" 
                               HorizontalAlignment="Center" Foreground="#333"/>
                    <Separator Margin="0,10,0,10"/>

                    <!-- Адрес -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,5,0,0">
                        <TextBlock Text="📍" FontSize="16" Margin="0,0,5,0"/>
                        <Label Content="Адрес:" FontWeight="Bold" FontSize="14"/>
                    </StackPanel>
                    <TextBox Style="{StaticResource RoundedTextBox}" x:Name="AdressTextBox" TextAlignment="Center" FontFamily="Calibri" KeyDown="AdressTextBox_KeyDown"></TextBox>

                    <!-- Блок -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,10,0,0">
                        <TextBlock Text="🏢" FontSize="16" Margin="0,0,5,0"/>
                        <Label Content="Блок:" FontWeight="Bold" FontSize="14"/>
                    </StackPanel>
                    <TextBox Style="{StaticResource RoundedTextBox}" x:Name="BlockTextBox" TextAlignment="Center" FontFamily="Calibri" KeyDown="BlockTextBox_KeyDown"></TextBox>

                    <!-- Вход -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,10,0,0">
                        <TextBlock Text="🚪" FontSize="16" Margin="0,0,5,0"/>
                        <Label Content="Вход:" FontWeight="Bold" FontSize="14"/>
                    </StackPanel>
                    <TextBox Style="{StaticResource RoundedTextBox}" x:Name="EntranceTextBox" TextAlignment="Center" FontFamily="Calibri" KeyDown="EntranceTextBox_KeyDown"></TextBox>
                    <!-- Апартамент -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                        <!-- Апартамент № -->
                        <StackPanel Orientation="Vertical" Margin="0,0,10,0">
                            <Label Content="🏠Апартамент №:" 
  FontFamily="Calibri" FontWeight="Bold" 
  HorizontalAlignment="Center" FontSize="16"/>
                            <TextBox Style="{StaticResource RoundedTextBox}" 
    x:Name="ApartmentNumberTextBox" 
    Height="33" TextAlignment="Center" Width="145"/>
                        </StackPanel>

                        <!-- Брой живущи -->
                        <StackPanel Orientation="Vertical">
                            <Label Content="👥Брой живущи:" 
  FontFamily="Calibri" FontWeight="Bold" 
  HorizontalAlignment="Center" FontSize="16"/>
                            <TextBox Style="{StaticResource RoundedTextBox}" 
    x:Name="ResidentsCountTextBox" 
    Height="34" TextAlignment="Center" Width="131" KeyDown="ResidentsCountTextBox_KeyDown"/>
                        </StackPanel>
                    </StackPanel>

                    <Button Style="{StaticResource MainButtonStyle}" Content="✏️ Редактирай"
                            Width="160" Height="45" HorizontalAlignment="Center" Margin="0,20,0,0"
                            x:Name="editAddressButton" Click="SavePropertyButton_Click"/>
                </StackPanel>
            </Border>

            <!-- Вертикален разделител -->
            <Border Grid.Column="1"
                    Width="1"
                    Background="#DDD"
                    VerticalAlignment="Stretch"
                    Margin="0,10"/>

            <!-- Дясна страна -->
            <Border Grid.Column="2" Grid.ColumnSpan="2" CornerRadius="10" Padding="20" Margin="10,0,0,0" 
                    BorderBrush="#DDD" BorderThickness="1" VerticalAlignment="Center" Height="416">
                <StackPanel VerticalAlignment="Center" Height="383">
                    <TextBlock Text="Редактиране на данни за контакт" 
                               FontFamily="Calibri" FontWeight="Bold" FontSize="18" 
                               HorizontalAlignment="Center" Foreground="#333"/>
                    <Separator Margin="0,10,0,10"/>

                    <!-- Име -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,5,0,0">
                        <TextBlock Text="👤" FontSize="16" Margin="0,0,5,0"/>
                        <Label Content="Име на собственик:" FontWeight="Bold" FontSize="14"/>
                    </StackPanel>
                    <TextBox Style="{StaticResource RoundedTextBox}" x:Name="ownerNameTxtBox" Height="36" TextAlignment="Center" KeyDown="ownerNameTxtBox_KeyDown"/>

                    <!-- Телефон -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,15,0,0">
                        <TextBlock Text="📞" FontSize="16" Margin="0,0,5,0"/>
                        <Label Content="Телефон на собственик:" FontWeight="Bold" FontSize="14"/>
                    </StackPanel>
                    <TextBox Style="{StaticResource RoundedTextBox}" x:Name="ownerPhoneNumberTxtBox" Height="36" TextAlignment="Center" KeyDown="ownerPhoneNumberTxtBox_KeyDown"/>

                    <Button Style="{StaticResource MainButtonStyle}" Content="✏️ Редактирай"
                            Width="160" Height="53" HorizontalAlignment="Center" Margin="0,20,0,24"
                            x:Name="editOwnerButton" Click="editOwnerButton_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
