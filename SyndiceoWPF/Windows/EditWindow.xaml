<Window x:Class="Syndiceo.Windows.EditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Syndiceo"
        mc:Ignorable="d"
        Title="Редактиране на данни"
        MinWidth="800" MinHeight="600"
        Width="850" Height="620"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Icon="pack://application:,,,/Resources/Ico/logo256.ico"
        Loaded="Window_Loaded" Background="#F8FAFC">

    <Grid Margin="0">
        <Grid Margin="25">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" CornerRadius="15" Background="White" Padding="20" Margin="0,0,10,0" 
                    BorderBrush="#E2E8F0" BorderThickness="1" VerticalAlignment="Stretch">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" Opacity="0.05" ShadowDepth="2" Color="#64748B"/>
                </Border.Effect>

                <StackPanel>
                    <TextBlock Text="🏠 Редактиране на обект" 
                               FontFamily="Segoe UI" FontWeight="Bold" FontSize="20" 
                               HorizontalAlignment="Left" Foreground="#1E293B"/>
                    <Separator Margin="0,15,0,20" Background="#F1F5F9" Height="1"/>

                    <StackPanel Margin="0,0,0,12">
                        <Label Content="Адрес (Улица):" FontWeight="SemiBold" FontSize="13" Foreground="#475569"/>
                        <TextBox Style="{StaticResource RoundedTextBox}" x:Name="AdressTextBox" 
                                 Height="38" TextAlignment="Left" Padding="10,0" VerticalContentAlignment="Center"
                                 KeyDown="AdressTextBox_KeyDown"/>
                    </StackPanel>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <Label Content="Блок:" FontWeight="SemiBold" FontSize="13" Foreground="#475569"/>
                            <TextBox Style="{StaticResource RoundedTextBox}" x:Name="BlockTextBox" 
                                     Height="38" TextAlignment="Center" KeyDown="BlockTextBox_KeyDown"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <Label Content="Вход:" FontWeight="SemiBold" FontSize="13" Foreground="#475569"/>
                            <TextBox Style="{StaticResource RoundedTextBox}" x:Name="EntranceTextBox" 
                                     Height="38" TextAlignment="Center" KeyDown="EntranceTextBox_KeyDown"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,5,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <Label Content="Апартамент №:" FontWeight="SemiBold" FontSize="13" Foreground="#475569"/>
                            <TextBox Style="{StaticResource RoundedTextBox}" x:Name="ApartmentNumberTextBox" 
                                     Height="38" FontWeight="Bold" FontSize="15" TextAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <Label Content="Брой живущи:" FontWeight="SemiBold" FontSize="13" Foreground="#475569"/>
                            <TextBox Style="{StaticResource RoundedTextBox}" x:Name="ResidentsCountTextBox" 
                                     Height="38" FontWeight="Bold" FontSize="15" TextAlignment="Center" 
                                     KeyDown="ResidentsCountTextBox_KeyDown"/>
                        </StackPanel>
                    </Grid>

                    <Button Style="{StaticResource MainButtonStyle}" Content="💾 Обнови адрес"
                            Width="200" Height="48" HorizontalAlignment="Center" Margin="0,20,0,0"
                            x:Name="editAddressButton" Click="SavePropertyButton_Click" Cursor="Hand"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" CornerRadius="15" Background="White" Padding="25" Margin="10,0,0,0" 
                    BorderBrush="#E2E8F0" BorderThickness="1" VerticalAlignment="Top">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" Opacity="0.05" ShadowDepth="2" Color="#64748B"/>
                </Border.Effect>

                <StackPanel>
                    <TextBlock Text="👤 Данни за собственик" 
                               FontFamily="Segoe UI" FontWeight="Bold" FontSize="18" 
                               HorizontalAlignment="Left" Foreground="#1E293B"/>
                    <Separator Margin="0,15,0,20" Background="#F1F5F9" Height="1"/>

                    <Label Content="Име на собственик:" FontWeight="SemiBold" FontSize="13" Foreground="#475569"/>
                    <TextBox Style="{StaticResource RoundedTextBox}" x:Name="ownerNameTxtBox" 
                             Height="40" Margin="0,0,0,15" Padding="10,0" VerticalContentAlignment="Center"
                             KeyDown="ownerNameTxtBox_KeyDown"/>

                    <Label Content="Телефон за връзка:" FontWeight="SemiBold" FontSize="13" Foreground="#475569"/>
                    <TextBox Style="{StaticResource RoundedTextBox}" x:Name="ownerPhoneNumberTxtBox" 
                             Height="40" Margin="0,0,0,15" Padding="10,0" VerticalContentAlignment="Center"
                             KeyDown="ownerPhoneNumberTxtBox_KeyDown"/>

                    <Button Style="{StaticResource MainButtonStyle}" Content="🔄 Обнови контакт"
                            Width="180" Height="48" HorizontalAlignment="Center" Margin="0,20,0,0"
                            x:Name="editOwnerButton" Click="editOwnerButton_Click" Cursor="Hand"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>