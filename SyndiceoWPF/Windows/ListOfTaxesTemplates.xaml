<Window x:Class="Syndiceo.Windows.ListOfTaxesTemplates"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Syndiceo"
        mc:Ignorable="d"
        Title="Принтиране" Height="639" Width="500"
        Icon="pack://application:,,,/Resources/Ico/logo128.ico"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen" Loaded="Window_Loaded">

    <Grid Margin="20" Background="#FFF">
        <!-- Воден знак -->
        <Image Source="/Resources/logo.png"
               Opacity="0.05"
               Stretch="Uniform"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               Panel.ZIndex="0"/>

        <Border CornerRadius="10" Padding="20" BorderBrush="#DDD" BorderThickness="1">
            <StackPanel>

                <TextBlock Text="Налични шаблони" 
                           FontFamily="Calibri" FontWeight="Bold" FontSize="18" 
                           HorizontalAlignment="Center" Foreground="#333" Margin="0,0,0,10"/>
                <ListBox x:Name="FilesListBox" Height="417" Background="Transparent" 
                         BorderBrush="#CCC" BorderThickness="1" FontFamily="Calibri" FontSize="16" Width="406"/>

                <!-- ListBox за файлове -->

                <!-- Бутони в хоризонтален StackPanel -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0" >
                    <Button Style="{StaticResource MainButtonStyle}" x:Name="OpenTemplateButton" Content="Зареди шаблона" Width="151" Height="40"
                            FontFamily="Calibri" FontWeight="Bold" FontSize="16" Click="OpenTemplateButton_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
